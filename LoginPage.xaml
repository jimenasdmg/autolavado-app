<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoLavadoApp.Views.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AutoLavadoApp.ViewModels.Auth"
    x:DataType="vm:AutenticacionViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource BrizzoLoginBlueDark}">

    <Grid>
    <ScrollView>
        <Grid Padding="24,12" MinimumHeightRequest="620">

            <VerticalStackLayout x:Name="LoginContent"
                                 VerticalOptions="Center"
                                 Spacing="14">

            <Image
                Source="brizzo_isotipo"
                HeightRequest="60"
                WidthRequest="60"
                HorizontalOptions="Center" />

            <Label
                Text="BRIZZO"
                FontSize="34"
                FontAttributes="Bold"
                CharacterSpacing="3"
                TextColor="White"
                HorizontalTextAlignment="Center" />

            <VerticalStackLayout Spacing="2" Margin="0,2,0,4">
                <Label
                    Text="Bienvenido"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />
                <Label
                    Text="Inicia sesión para continuar"
                    FontSize="13"
                    TextColor="#C7D2E5"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                <Border
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 14"
                    Padding="12,6">
                    <Entry
                        Placeholder="Correo electrónico"
                        Text="{Binding Email}"
                        Keyboard="Email"
                        HeightRequest="42"
                        TextColor="White"
                        PlaceholderColor="#A9B3C7"
                        ClearButtonVisibility="WhileEditing"
                        IsEnabled="{Binding CanInteract}" />
                </Border>

                <Label
                    Text="{Binding EmailError}"
                    FontSize="12"
                    TextColor="#FCA5A5"
                    Margin="2,-6,2,0"
                    IsVisible="{Binding HasEmailError}" />

                <Border
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 14"
                    Padding="12,6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry
                            Placeholder="Contraseña"
                            Text="{Binding Password}"
                            IsPassword="{Binding IsPasswordHidden}"
                            HeightRequest="42"
                            TextColor="White"
                            PlaceholderColor="#A9B3C7"
                            IsEnabled="{Binding CanInteract}" />
                        <Button
                            Grid.Column="1"
                            Text="{Binding PasswordEyeIcon}"
                            FontFamily="FontAwesomeSolid"
                            BackgroundColor="Transparent"
                            TextColor="#A9B3C7"
                            Padding="4,0"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            IsEnabled="{Binding CanInteract}" />
                    </Grid>
                </Border>

                <Label
                    Text="{Binding PasswordError}"
                    FontSize="12"
                    TextColor="#FCA5A5"
                    Margin="2,-6,2,0"
                    IsVisible="{Binding HasPasswordError}" />

                <Label
                    Text="{Binding ErrorMessage}"
                    FontSize="13"
                    TextColor="#FCA5A5"
                    IsVisible="{Binding HasError}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" Margin="0,8,0,0">
                <Button
                    x:Name="LoginPrimaryButton"
                    Text="Iniciar sesión"
                    HeightRequest="50"
                    CornerRadius="14"
                    BackgroundColor="{StaticResource BrizzoLoginBlueBright}"
                    TextColor="White"
                    FontAttributes="Bold"
                    Shadow="0,6,16,#401E88E5"
                    IsEnabled="{Binding CanInteract}"
                    Pressed="OnActionButtonPressed"
                    Released="OnActionButtonReleased"
                    Clicked="OnIniciarSesionClicked" />

                <Button
                    Text="Crear cuenta"
                    BackgroundColor="Transparent"
                    FontSize="15"
                    TextColor="White"
                    IsEnabled="{Binding CanInteract}"
                    Clicked="OnIrCrearCuentaClicked" />
            </VerticalStackLayout>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>

    <Grid IsVisible="{Binding IsBusy}"
          BackgroundColor="#660B1630"
          InputTransparent="False">
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="White"
                               WidthRequest="40"
                               HeightRequest="40" />
            <Label Text="Iniciando sesión..."
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="White" />
        </VerticalStackLayout>
    </Grid>
    </Grid>
</ContentPage>
