<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.Views.Admin.AdminServiciosPage"
             Shell.NavBarIsVisible="False"
             Padding="0,18,0,0"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24,18" Spacing="14">
                <Label Text="Servicios"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <Label Text="Administra catálogo y precios BRIZZO"
                       FontSize="14"
                       TextColor="#64748B" />

                <Button Text="Agregar servicio"
                        HeightRequest="46"
                        CornerRadius="12"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        ImageSource="{FontImageSource Glyph=&#xF067;, FontFamily=FontAwesomeSolid, Size=14, Color=White}"
                        ContentLayout="Left,8"
                        Clicked="OnAgregarServicioClicked" />

                <CollectionView ItemsSource="{Binding Servicios}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14"
                                    Margin="0,0,0,18"
                                    HorizontalOptions="Fill">
                                <Border.Shadow>
                                    <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border WidthRequest="38"
                                                    HeightRequest="38"
                                                    VerticalOptions="Start"
                                                    BackgroundColor="#DBEAFE"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 19">
                                                <Label Text="{Binding ImagenVisual}"
                                                       FontFamily="FontAwesomeSolid"
                                                       FontSize="16"
                                                       TextColor="#1D4ED8"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label Text="{Binding Nombre}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#0B1F4D"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                                <Label Text="{Binding Descripcion}"
                                                       FontSize="13"
                                                       TextColor="#64748B"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />
                                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                                                    <Label Text="{Binding PrecioTexto}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#2563EB"
                                                           VerticalTextAlignment="Center" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DuracionTexto}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#6366F1"
                                                           VerticalTextAlignment="Center" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding EstadoFondo}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,4"
                                                VerticalOptions="Start"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding EstadoTexto}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding EstadoColor}" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button Grid.Column="0"
                                                Text="Editar"
                                                HeightRequest="42"
                                                CornerRadius="14"
                                                BackgroundColor="#EFF6FF"
                                                TextColor="#1E40AF"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnEditarServicioClicked" />
                                        <Button Grid.Column="1"
                                                Text="{Binding ToggleEstadoTexto}"
                                                HeightRequest="42"
                                                CornerRadius="14"
                                                BackgroundColor="#F1F5F9"
                                                TextColor="#334155"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarEstadoServicioClicked" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
