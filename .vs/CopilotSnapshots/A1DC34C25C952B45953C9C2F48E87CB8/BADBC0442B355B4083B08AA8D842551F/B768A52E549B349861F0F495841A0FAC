<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AutoLavadoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewsAuth="clr-namespace:AutoLavadoApp.Views.Auth"
    xmlns:viewsCliente="clr-namespace:AutoLavadoApp.Views.Cliente"
    xmlns:viewsAdmin="clr-namespace:AutoLavadoApp.Views.Admin"
    xmlns:viewsEmpleado="clr-namespace:AutoLavadoApp.Views.Empleado"
    xmlns:viewsShared="clr-namespace:AutoLavadoApp.Views.Shared"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="#7B849B"
    Shell.TabBarUnselectedColor="#7B849B"
    Shell.TabBarForegroundColor="#0B1F5C"
    BackgroundColor="#F5F7FB">

  <!-- Página de Login (ruta inicial) -->
  <ShellContent
      Title="Inicio"
      ContentTemplate="{DataTemplate viewsAuth:LoginPage}"
      Route="LoginPage" />

  <!-- Barra de pestañas con iconos (usa Resources/Images/*.svg) -->
  <TabBar>
    <ShellContent Title="Inicio" ContentTemplate="{DataTemplate viewsCliente:HomePage}" Icon="home.svg" Route="HomePage" />
    <ShellContent Title="Mis Citas" ContentTemplate="{DataTemplate viewsCliente:MisCitasPage}" Icon="calendar.svg" Route="MisCitasPage" />
    <ShellContent Title="Mi Cuenta" ContentTemplate="{DataTemplate viewsCliente:MiCuentaPage}" Icon="account.svg" Route="MiCuentaPage" />
  </TabBar>

</Shell>
