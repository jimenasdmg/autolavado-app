<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.AdminEmpleadosPage"
             Shell.NavBarIsVisible="False"
             Padding="0,18,0,0"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24,18" Spacing="16">
                <Label Text="Empleados"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <Label Text="Gestiona el equipo BRIZZO"
                       FontSize="14"
                       TextColor="#64748B" />

                <Button Text="Agregar empleado"
                        HeightRequest="46"
                        CornerRadius="12"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        ImageSource="{FontImageSource Glyph=&#xF234;, FontFamily=FontAwesomeSolid, Size=14, Color=White}"
                        ContentLayout="Left,8"
                        Clicked="OnAgregarEmpleadoClicked" />

                <CollectionView ItemsSource="{Binding Empleados}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="14"
                                    Margin="0,0,0,18"
                                    HorizontalOptions="Fill">
                                <Border.Shadow>
                                    <Shadow Brush="#12000000" Offset="0,2" Radius="8" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border WidthRequest="44"
                                                HeightRequest="44"
                                                BackgroundColor="#DBEAFE"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 22">
                                            <Label Text="{Binding Inicial}"
                                                   FontSize="17"
                                                   FontAttributes="Bold"
                                                   TextColor="#1D4ED8"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Fill">
                                            <Label Text="{Binding NombreCompleto}" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" LineBreakMode="TailTruncation" MaxLines="2" HorizontalOptions="Fill" />
                                            <Label Text="{Binding EstadoTexto}" FontSize="12" TextColor="#64748B" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2"
                                                VerticalOptions="Center"
                                                Padding="8,4"
                                                BackgroundColor="{Binding EstadoBadgeFondo}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10">
                                            <Label Text="{Binding EstadoTexto}" FontSize="11" FontAttributes="Bold" TextColor="{Binding EstadoColor}" />
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="*">
                                        <Button Text="{Binding EstadoTexto}"
                                                HeightRequest="46"
                                                CornerRadius="12"
                                                BackgroundColor="{Binding EstadoBadgeFondo}"
                                                TextColor="{Binding EstadoColor}"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarEstadoEmpleadoClicked" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
