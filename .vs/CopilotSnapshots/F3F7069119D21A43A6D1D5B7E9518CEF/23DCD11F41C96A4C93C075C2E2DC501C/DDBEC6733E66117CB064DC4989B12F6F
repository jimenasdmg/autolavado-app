<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.EmpleadoCitasPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="18,16,18,20" Spacing="12">
                <Label Text="Citas"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <!-- Trabajos disponibles (citas sin empleado asignado) -->
                <Label Text="Trabajos disponibles"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D"
                       IsVisible="{Binding TrabajosDisponibles.Count, Converter={StaticResource IntToBoolConverter}}" />

                <CollectionView ItemsSource="{Binding TrabajosDisponibles}"
                                SelectionMode="None"
                                IsVisible="{Binding TrabajosDisponibles.Count, Converter={StaticResource IntToBoolConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Border.Shadow>
                                    <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="9">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="{Binding NombreCliente}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#0B1F4D" />
                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding EstadoBackgroundColor}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,5">
                                            <Label Text="{Binding Estado}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding EstadoColor}" />
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Vehiculo}" FontSize="13" TextColor="#334155" />
                                    <Label Text="{Binding Servicio}" FontSize="13" TextColor="#334155" />
                                    <Label Text="{Binding Hora}" FontSize="13" TextColor="#334155" />

                                    <Grid ColumnDefinitions="*" ColumnSpacing="8">
                                        <Button Text="Tomar trabajo"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                BackgroundColor="#DBEAFE"
                                                TextColor="#1D4ED8"
                                                FontAttributes="Bold"
                                                Command="{Binding TomarTrabajoCommand}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Citas asignadas"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D"
                       Margin="0,8,0,0" />

                <CollectionView ItemsSource="{Binding CitasAsignadas}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Border.Shadow>
                                    <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="9">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="{Binding NombreCliente}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#0B1F4D" />
                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding EstadoBackgroundColor}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,5">
                                            <Label Text="{Binding Estado}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding EstadoColor}" />
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Vehiculo}" FontSize="13" TextColor="#334155" />
                                    <Label Text="{Binding Servicio}" FontSize="13" TextColor="#334155" />
                                    <Label Text="{Binding Hora}" FontSize="13" TextColor="#334155" />

                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                        <Button Text="Confirmar"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                BackgroundColor="#DBEAFE"
                                                TextColor="#1D4ED8"
                                                FontAttributes="Bold"
                                                Command="{Binding ConfirmarCommand}"
                                                IsVisible="{Binding PuedeConfirmar}" />

                                        <Button Grid.Column="1"
                                                Text="Iniciar"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                BackgroundColor="#EDE9FE"
                                                TextColor="#6D28D9"
                                                FontAttributes="Bold"
                                                Command="{Binding IniciarServicioCommand}"
                                                IsVisible="{Binding PuedeIniciar}" />

                                        <Button Grid.Row="1"
                                                Text="Finalizar"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                BackgroundColor="#DCFCE7"
                                                TextColor="#15803D"
                                                FontAttributes="Bold"
                                                Command="{Binding FinalizarCommand}"
                                                IsVisible="{Binding PuedeFinalizar}" />

                                        <Button Grid.Row="1"
                                                Grid.Column="1"
                                                Text="Cancelar"
                                                HeightRequest="40"
                                                CornerRadius="10"
                                                BackgroundColor="#FEE2E2"
                                                TextColor="#B91C1C"
                                                FontAttributes="Bold"
                                                Command="{Binding CancelarCommand}"
                                                IsVisible="{Binding PuedeCancelar}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
