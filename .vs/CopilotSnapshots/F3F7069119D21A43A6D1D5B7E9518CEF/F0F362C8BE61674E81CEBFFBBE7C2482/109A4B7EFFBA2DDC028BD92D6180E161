        private void LogDebug(string message)
        {
            _logger?.LogDebug(message);
            Debug.WriteLine(message);
        }

        private void LogError(Exception ex, string message)
        {
            _logger?.LogError(ex, message);
            Debug.WriteLine($"[AdminDashboard][Error] {message}");
            Debug.WriteLine(ex.ToString());
        }

        private static void ValidarTokenSesion(string? idToken)
        {
            if (string.IsNullOrWhiteSpace(idToken))
            {
                throw new InvalidOperationException("No hay idToken en la sesión actual.");
            }

            if (SessionService.TokenExpirado(idToken))
            {
                throw new UnauthorizedAccessException("El idToken de Firebase expiró. Vuelve a iniciar sesión.");
            }
        }

        private void ActualizarResumen()
        {
            var hoy = DateTime.Today;
            CitasHoy = 0;
            Pendientes = 0;
            Finalizadas = 0;
            IngresosEstimados = 0;

            foreach (var cita in CitasGlobales)
            {
                if (cita.Fecha.Date == hoy)
                {
                    CitasHoy++;
                }

                if (cita.Estado == "Pendiente")
                {
                    Pendientes++;
                }

                if (cita.Estado == "Finalizada")
                {
                    Finalizadas++;
                    IngresosEstimados += 250m;
                }
            }

            EmpleadosActivos = 0;
            foreach (var empleado in Empleados)
            {
                if (empleado.Activo)
                {
                    EmpleadosActivos++;
                }
            }

            OnPropertyChanged(nameof(IngresosEstimadosTexto));
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }

