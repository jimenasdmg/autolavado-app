        public async Task<List<CitaAdminItem>> ObtenerHistorialEmpleadoAsync(string empleadoId)
        {
            var idToken = await _session_service.ObtenerTokenAsync();
            ValidarTokenSesion(idToken);
            var citas = await _citaService.ObtenerHistorialPorEmpleadoAsync(empleadoId, idToken);
            var result = new List<CitaAdminItem>();
            foreach (var cita in citas)
            {
                result.Add(new CitaAdminItem
                {
                    ClienteId = string.IsNullOrWhiteSpace(cita.ClienteNombre) ? cita.UsuarioId : cita.ClienteNombre,
                    Servicio = string.IsNullOrWhiteSpace(cita.ServicioNombre) ? cita.ServicioId : cita.ServicioNombre,
                    Fecha = cita.Fecha,
                    Hora = cita.Hora,
                    Estado = cita.Estado,
                    Vehiculo = string.IsNullOrWhiteSpace(cita.Vehiculo) ? cita.VehiculoId : cita.Vehiculo,
                    Empleado = string.IsNullOrWhiteSpace(cita.EmpleadoNombre) ? cita.EmpleadoId : cita.EmpleadoNombre,
                    Comentarios = cita.Observaciones,
                    Pagado = cita.Pagado
                });
            }

            return result;
        }

        public async Task EliminarEmpleadoAsync(EmpleadoAdminItem empleado)
        {
            if (empleado == null) return;

            var idToken = await _sessionService.ObtenerTokenAsync();
            ValidarTokenSesion(idToken);

            try
            {
                var eliminado = await _empleadoService.EliminarEmpleadoAsync(empleado.Id, idToken);
                if (!eliminado)
                {
                    if (MostrarAlertaAsync != null)
                        await MostrarAlertaAsync("Error", "No fue posible eliminar al empleado.", "OK");
                    return;
                }

                // Eliminar de la colección en memoria
                var existente = Empleados.FirstOrDefault(e => e.Id == empleado.Id);
                if (existente != null) Empleados.Remove(existente);
            }
            catch (Exception ex)
            {
                LogError(ex, "Error al eliminar empleado.");
                if (MostrarAlertaAsync != null)
                    await MostrarAlertaAsync("Error", "Ocurrió un error al eliminar al empleado.", "OK");
            }
        }

