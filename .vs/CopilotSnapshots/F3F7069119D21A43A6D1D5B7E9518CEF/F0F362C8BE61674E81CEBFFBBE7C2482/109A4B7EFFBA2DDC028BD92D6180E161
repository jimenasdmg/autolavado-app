        public async Task AgregarServicioAsync()
        {
            if (SolicitarInputAsync == null)
            {
                return;
            }

            var nombre = await SolicitarInputAsync("Nuevo servicio", "Nombre", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(nombre))
            {
                return;
            }

            var descripcion = await SolicitarInputAsync("Nuevo servicio", "Descripción", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(descripcion))
            {
                return;
            }

            var precioRaw = await SolicitarInputAsync("Nuevo servicio", "Precio", "Guardar", "Cancelar", "");
            if (!decimal.TryParse(precioRaw, NumberStyles.Any, CultureInfo.InvariantCulture, out var precio)
                && !decimal.TryParse(precioRaw, NumberStyles.Any, CultureInfo.GetCultureInfo("es-MX"), out precio))
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Precio inválido", "Ingresa un precio numérico válido.", "OK");
                }
                return;
            }

            var duracionRaw = await SolicitarInputAsync("Nuevo servicio", "Duración en minutos", "Guardar", "Cancelar", "60");
            if (!int.TryParse(duracionRaw, out var duracion) || duracion <= 0)
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Duración inválida", "Ingresa una duración válida en minutos.", "OK");
                }
                return;
            }

            var imagen = await SolicitarInputAsync("Nuevo servicio", "Icono o URL de imagen", "Guardar", "Cancelar", "\uf043") ?? string.Empty;
            var visibleRaw = await SolicitarInputAsync("Nuevo servicio", "Visible para clientes (si/no)", "Guardar", "Cancelar", "si") ?? "si";
            var activoRaw = await SolicitarInputAsync("Nuevo servicio", "Activo (si/no)", "Guardar", "Cancelar", "si") ?? "si";
            var visibleClientes = EsRespuestaAfirmativa(visibleRaw);
            var activo = EsRespuestaAfirmativa(activoRaw);

            var idToken = await _sessionService.ObtenerTokenAsync();
            ValidarTokenSesion(idToken);
            await _servicioService.CrearServicioAsync(
                nombre.Trim(),
                descripcion.Trim(),
                precio,
                duracion,
                activo,
                visibleClientes,
                imagen.Trim(),
                idToken);
            await CargarServiciosAsync(idToken);
        }

        public async Task EditarServicioAsync(ServicioAdminItem servicio)
        {
            if (servicio == null || SolicitarInputAsync == null)
            {
                return;
            }

            var nuevoNombre = await SolicitarInputAsync("Editar servicio", "Nombre", "Guardar", "Cancelar", servicio.Nombre);
            if (string.IsNullOrWhiteSpace(nuevoNombre))
            {
                return;
            }

            var nuevaDescripcion = await SolicitarInputAsync("Editar servicio", "Descripción", "Guardar", "Cancelar", servicio.Descripcion);
            if (string.IsNullOrWhiteSpace(nuevaDescripcion))
            {
                return;
            }

            var nuevoPrecioRaw = await SolicitarInputAsync("Editar servicio", "Precio", "Guardar", "Cancelar", servicio.Precio.ToString("N2", CultureInfo.InvariantCulture));
            if (!decimal.TryParse(nuevoPrecioRaw, NumberStyles.Any, CultureInfo.InvariantCulture, out var nuevoPrecio)
                && !decimal.TryParse(nuevoPrecioRaw, NumberStyles.Any, CultureInfo.GetCultureInfo("es-MX"), out nuevoPrecio))
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Precio inválido", "Ingresa un precio numérico válido.", "OK");
                }
                return;
            }

            var nuevaDuracionRaw = await SolicitarInputAsync("Editar servicio", "Duración en minutos", "Guardar", "Cancelar", servicio.DuracionMinutos.ToString());
            if (!int.TryParse(nuevaDuracionRaw, out var nuevaDuracion) || nuevaDuracion <= 0)
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Duración inválida", "Ingresa una duración válida en minutos.", "OK");
                }
                return;
            }

            var nuevaImagen = await SolicitarInputAsync("Editar servicio", "Icono o URL de imagen", "Guardar", "Cancelar", servicio.Imagen ?? string.Empty) ?? string.Empty;

            var idToken = await _sessionService.ObtenerTokenAsync();
            ValidarTokenSesion(idToken);
            await _servicioService.EditarServicioAsync(
                servicio.Id,
                nuevoNombre.Trim(),
                nuevaDescripcion.Trim(),
                nuevoPrecio,
                nuevaDuracion,
                nuevaImagen.Trim(),
                idToken);
            await CargarServiciosAsync(idToken);
        }

