        private async Task CargarCitasGlobalesAsync(string idToken)
        {
            LogDebug("[AdminDashboard] Consultando colección 'citas'.");
            var citas = await _citaService.ObtenerTodasCitasAsync(idToken);
            CitasGlobales.Clear();

            foreach (var cita in citas)
            {
                CitasGlobales.Add(new CitaAdminItem
                {
                    ClienteId = string.IsNullOrWhiteSpace(cita.ClienteNombre) ? cita.UsuarioId : cita.ClienteNombre,
                    Servicio = string.IsNullOrWhiteSpace(cita.ServicioNombre) ? cita.ServicioId : cita.ServicioNombre,
                    Fecha = cita.Fecha,
                    Hora = cita.Hora,
                    Estado = cita.Estado,
                    Vehiculo = string.IsNullOrWhiteSpace(cita.Vehiculo) ? cita.VehiculoId : cita.Vehiculo,
                    Empleado = string.IsNullOrWhiteSpace(cita.EmpleadoNombre) ? cita.EmpleadoId : cita.EmpleadoNombre,
                    Comentarios = cita.Observaciones
                });
            }

            LogDebug($"[AdminDashboard] Colección 'citas' cargada. Registros={CitasGlobales.Count}");
        }

        private async Task EjecutarDiagnosticoColeccionesAsync(string idToken)
        {
            var sb = new StringBuilder();
            sb.AppendLine("[AdminDashboard] Diagnóstico de Firebase:");

            var uid = _sessionService.ObtenerUid();
            var rol = _sessionService.ObtenerRol();
            sb.AppendLine($"- SessionService.uid: {(string.IsNullOrWhiteSpace(uid) ? "(vacío)" : uid)}");
            sb.AppendLine($"- SessionService.rol: {(string.IsNullOrWhiteSpace(rol) ? "(vacío)" : rol)}");
            sb.AppendLine($"- SessionService.token vacío: {string.IsNullOrWhiteSpace(idToken)}");

            var admin = await _usuarioService.ObtenerUsuarioPorIdAsync(uid, idToken);
            sb.AppendLine($"- Usuario actual en colección 'usuarios': {(admin == null ? "NO encontrado" : "OK")}");
            if (admin != null)
            {
                sb.AppendLine($"- Rol usuario actual en Firebase: {admin.Rol}");
            }

            var citas = await _citaService.ObtenerTodasCitasAsync(idToken);
            sb.AppendLine($"- Colección 'citas': {citas.Count} documentos");

            var empleadosDesdeUsuarios = await _empleadoService.ObtenerEmpleadosAsync(idToken);
            sb.AppendLine($"- Colección 'usuarios' (admins/empleados): {empleadosDesdeUsuarios.Count} documentos");

            var empleadosDirecto = await _empleadoService.ObtenerEmpleadosDesdeColeccionEmpleadosAsync(idToken);
            sb.AppendLine($"- Colección 'empleados': {empleadosDirecto.Count} documentos (0 puede indicar vacía o inexistente)");

            var servicios = await _servicioService.ObtenerServiciosAsync(idToken);
            sb.AppendLine($"- Colección 'servicios': {servicios.Count} documentos");

            LogDebug(sb.ToString());
        }

        private async Task CargarEmpleadosAsync(string idToken)
        {
            LogDebug("[AdminDashboard] Consultando colección 'usuarios' (empleados/admin). ");
            var empleados = await _empleadoService.ObtenerEmpleadosAsync(idToken);
            Empleados.Clear();

            foreach (var empleado in empleados)
            {
                Empleados.Add(new EmpleadoAdminItem
                {
                    Id = empleado.Id,
                    Nombre = empleado.Nombre,
                    ApellidoPaterno = empleado.ApellidoPaterno,
                    ApellidoMaterno = empleado.ApellidoMaterno,
                    Email = empleado.Email,
                    Rol = empleado.Rol,
                    Activo = empleado.Activo
                });
            }

            LogDebug($"[AdminDashboard] Empleados cargados. Registros={Empleados.Count}");
        }

        private async Task CargarServiciosAsync(string idToken)
        {
            LogDebug("[AdminDashboard] Consultando colección 'servicios'.");
            var servicios = await _servicioService.ObtenerServiciosAsync(idToken);
            Servicios.Clear();

            foreach (var servicio in servicios)
            {
                Servicios.Add(new ServicioAdminItem
                {
                    Id = servicio.Id,
                    Nombre = servicio.Nombre,
                    Descripcion = servicio.Descripcion,
                    Precio = servicio.Precio,
                    DuracionMinutos = servicio.DuracionMinutos,
                    Activo = servicio.Activo,
                    VisibleClientes = servicio.Visible,
                    Imagen = servicio.Imagen
                });
            }

            LogDebug($"[AdminDashboard] Servicios cargados. Registros={Servicios.Count}");
        }

        private static bool EsRespuestaAfirmativa(string? value)
        {
            if (string.IsNullOrWhiteSpace(value)) return false;
            var normalized = value.Trim().ToLowerInvariant();
            return normalized is "si" or "sí" or "s" or "true" or "1" or "y" or "yes";
        }

