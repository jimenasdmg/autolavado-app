        public async Task CargarDashboardAsync()
        {
            if (IsBusy)
            {
                return;
            }

            try
            {
                IsBusy = true;

                var sesion = await ObtenerContextoSesionAdminAsync();
                LogDebug($"[AdminDashboard] Sesión activa. Uid={sesion.Uid}, Rol={sesion.Rol}");

                await CargarAdministradorAsync(sesion.Uid, sesion.Token);

                await CargarCitasGlobalesAsync(sesion.Token);
                await CargarEmpleadosAsync(sesion.Token);
                await CargarServiciosAsync(sesion.Token);
                await CargarMensajesNoLeidosAsync(sesion.Uid, sesion.Token);
                ActualizarResumen();

                LogDebug($"[AdminDashboard] Carga completada. Citas={CitasGlobales.Count}, Empleados={Empleados.Count}, Servicios={Servicios.Count}");
            }
            catch (Exception ex)
            {
                LogError(ex, "Error al cargar panel administrador.");

                if (MostrarAlertaAsync != null)
                {
                    var mensaje = ex.ToString();
                    await MostrarAlertaAsync("Error", mensaje, "OK");
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        private async Task<ContextoSesionAdmin> ObtenerContextoSesionAdminAsync()
        {
            var uid = _sessionService.ObtenerUid();
            var rol = _sessionService.ObtenerRol();
            var token = await _sessionService.ObtenerTokenAsync();

            if (string.IsNullOrWhiteSpace(uid))
            {
                throw new InvalidOperationException("No hay un usuario autenticado en SessionService (uid vacío).");
            }

            if (string.IsNullOrWhiteSpace(token))
            {
                throw new InvalidOperationException("La sesión actual no tiene token de Firebase.");
            }

            if (SessionService.TokenExpirado(token))
            {
                throw new UnauthorizedAccessException("El token de sesión de Firebase expiró. Inicia sesión nuevamente.");
            }

            if (!string.Equals(rol, "admin", StringComparison.OrdinalIgnoreCase))
            {
                throw new UnauthorizedAccessException($"El rol actual '{rol}' no tiene acceso al panel administrador.");
            }

            return new ContextoSesionAdmin(uid, token, rol);
        }

        private async Task CargarAdministradorAsync(string uid, string token)
        {
            LogDebug("[AdminDashboard] Consultando perfil de usuario actual en Firebase (colección usuarios).");
            var usuario = await _usuarioService.ObtenerUsuarioPorIdAsync(uid, token);

            if (usuario == null || string.IsNullOrWhiteSpace(usuario.Nombre))
            {
                NombreAdministrador = "Administrador";
                return;
            }

            if (!string.Equals(usuario.Rol, "admin", StringComparison.OrdinalIgnoreCase))
            {
                throw new UnauthorizedAccessException($"El usuario autenticado no es admin en Firebase. Rol detectado: '{usuario.Rol}'.");
            }

            var nombre = $"{usuario.Nombre} {usuario.ApellidoPaterno}".Trim();
            NombreAdministrador = string.IsNullOrWhiteSpace(nombre) ? "Administrador" : nombre;
        }

