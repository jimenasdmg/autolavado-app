        public string VisibleFondo => VisibleClientes ? "#DBEAFE" : "#F1F5F9";
        public string ImagenVisual => string.IsNullOrWhiteSpace(Imagen) ? "\uf043" : Imagen;
        public string ToggleEstadoTexto => Activo ? "Desactivar" : "Activar";
        public string ToggleVisibleTexto => VisibleClientes ? "Ocultar" : "Mostrar";
    }

