using System.Reflection;
using AutoLavadoApp.ViewModels;

namespace AutoLavadoApp;

public partial class LoginPage : ContentPage
{
    private readonly AutenticacionViewModel _authViewModel;

    public LoginPage()
    {
        InitializeComponent();
        NavigationPage.SetHasNavigationBar(this, false);

        _authViewModel = IPlatformApplication.Current?.Services.GetService<AutenticacionViewModel>()
            ?? throw new InvalidOperationException("No se pudo resolver AutenticacionViewModel desde DI.");

        BindingContext = _authViewModel;
    }

    private async void OnIniciarSesionClicked(object? sender, EventArgs e)
    {
        var ok = await _authViewModel.LoginAsync(_authViewModel.Email, _authViewModel.Password);
        if (!ok) return;

        await DisplayAlertAsync("✅ Bienvenido", "Inicio de sesión correcto.", "Continuar");

        var rol = ObtenerRol(_authViewModel.UsuarioActual);
        Page destino = rol switch
        {
            "empleado" => new EmpleadoHomePage(),
            "admin" => new AdminTabbedPage(),
            _ => new HomePage()
        };

        if (Application.Current?.Windows.Count > 0)
        {
            Application.Current.Windows[0].Page = new NavigationPage(destino);
        }
    }

    private async void OnIrCrearCuentaClicked(object? sender, EventArgs e)
    {
        await Navigation.PushAsync(new RegisterPage());
    }

    private static string ObtenerRol(object? usuario)
    {
        if (usuario is null) return "cliente";

        var prop = usuario.GetType().GetProperty("Rol", BindingFlags.Public | BindingFlags.Instance);
        var value = prop?.GetValue(usuario)?.ToString();
        return string.IsNullOrWhiteSpace(value) ? "cliente" : value.ToLowerInvariant();
    }
}
