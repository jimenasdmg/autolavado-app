using System;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;
using AutoLavadoApp.Services;

namespace AutoLavadoApp.ViewModels
{
    public class AutenticacionViewModel : INotifyPropertyChanged
    {
        private readonly AuthService _authService;
        private readonly SessionService _sessionService;
        private readonly UsuarioService _usuarioService;
        private Usuario? _usuarioActual;
        private string _idToken = string.Empty;
        private bool _estaAutenticado;
        private string _mensajeError = string.Empty;
        private bool _isBusy;

        public event PropertyChangedEventHandler? PropertyChanged;

        public AutenticacionViewModel(AuthService authService, SessionService sessionService, UsuarioService usuarioService)
        {
            _authService = authService;
            _sessionService = sessionService;
            _usuarioService = usuarioService;
            LoginCommand = new Command(async () => await ExecuteLoginAsync(), () => CanLogin());
            LogoutCommand = new Command(ExecuteLogout, () => EstaAutenticado);
        }

        public string IdToken
        {
            get => _idToken;
            private set
            {
                if (_idToken != value)
                {
                    _idToken = value;
                    OnPropertyChanged();
                }
            }
        }

        public Usuario? UsuarioActual
        {
            get => _usuarioActual;
            private set
            {
                if (_usuarioActual != value)
                {
                    _usuarioActual = value;
                    OnPropertyChanged();
                    EstaAutenticado = value != null;
                }
            }
        }

        public bool EstaAutenticado
        {
            get => _estaAutenticado;
            private set
            {
                if (_estaAutenticado != value)
                {
                    _estaAutenticado = value;
                    OnPropertyChanged();
                    ((Command)LogoutCommand).ChangeCanExecute();
                }
            }
        }

        public string MensajeError
        {
            get => _mensajeError;
            private set
            {
                if (_mensajeError != value)
                {
                    _mensajeError = value;
                    OnPropertyChanged();
                    OnPropertyChanged(nameof(HasError));
                }
            }
        }

        public bool HasError => !string.IsNullOrWhiteSpace(MensajeError);

        public bool IsBusy
        {
            get => _isBusy;
            private set
            {
                if (_isBusy != value)
                {
                    _isBusy = value;
                    OnPropertyChanged();
                    OnPropertyChanged(nameof(CanInteract));
                    ((Command)LoginCommand).ChangeCanExecute();
                }
            }
        }

        public bool CanInteract => !IsBusy;

        public ICommand LoginCommand { get; }
        public ICommand LogoutCommand { get; }

        public async Task<bool> LoginAsync(string? email, string? password)
        {
            if (IsBusy)
            {
                return false;
            }

            MensajeError = string.Empty;

            if (!CanLogin())
            {
                MensajeError = "Debes capturar email y contraseña.";
                return false;
            }

            try
            {
                IsBusy = true;

                var result = await _authService.LoginAsync(email ?? string.Empty, password ?? string.Empty);

                if (!result.IsSuccess)
                {
                    MensajeError = result.ErrorMessage;
                    return false;
                }

                var perfil = await _usuarioService.ObtenerClientePorIdAsync(result.UserId, result.IdToken)
                    ?? await _usuarioService.ObtenerUsuarioPorIdAsync(result.UserId, result.IdToken);

                var rol = perfil?.Rol ?? "cliente";

                IdToken = result.IdToken;
                UsuarioActual = new Usuario
                {
                    Id = result.UserId,
                    Email = email ?? string.Empty,
                    Nombre = perfil?.Nombre ?? email ?? string.Empty,
                    ApellidoPaterno = perfil?.ApellidoPaterno ?? string.Empty,
                    ApellidoMaterno = perfil?.ApellidoMaterno ?? string.Empty,
                    Rol = rol
                };

                var nombreSesion = string.IsNullOrWhiteSpace(perfil?.Nombre)
                    ? email?.Trim()
                    : $"{perfil!.Nombre} {perfil.ApellidoPaterno}".Trim();

                await _sessionService.GuardarSesionAsync(result.UserId, email?.Trim() ?? string.Empty, result.IdToken, rol, nombreSesion);

                return true;
            }
            catch (FirebaseServiceException ex)
            {
                MensajeError = ex.Message;
                return false;
            }
            catch
            {
                MensajeError = "Ocurrió un problema al iniciar sesión. Intenta nuevamente.";
                return false;
            }
            finally
            {
                IsBusy = false;
            }
        }

        public async Task<bool> RegisterAsync(string? email, string? password)
        {
            if (IsBusy)
            {
                return false;
            }

            MensajeError = string.Empty;

            if (!CanLogin())
            {
                MensajeError = "Debes capturar email y contraseña.";
                return false;
            }

            try
            {
                IsBusy = true;

                var result = await _authService.RegisterAsync(email ?? string.Empty, password ?? string.Empty);
                if (!result.IsSuccess)
                {
                    MensajeError = result.ErrorMessage;
                    return false;
                }

                IdToken = result.IdToken;
                UsuarioActual = new Usuario
                {
                    Id = result.UserId,
                    Email = email ?? string.Empty,
                    Nombre = email ?? string.Empty,
                    Rol = "cliente"
                };

                await _sessionService.GuardarSesionAsync(result.UserId, email?.Trim() ?? string.Empty, result.IdToken, "cliente", email?.Trim() ?? string.Empty);

                return true;
            }
            catch (FirebaseServiceException ex)
            {
                MensajeError = ex.Message;
                return false;
            }
            catch
            {
                MensajeError = "Ocurrió un problema al registrar la cuenta. Intenta nuevamente.";
                return false;
            }
            finally
            {
                IsBusy = false;
            }
        }

        public void Logout()
        {
            ExecuteLogout();
        }

        private bool CanLogin()
        {
            return !IsBusy && !string.IsNullOrWhiteSpace(UsuarioActual?.Email) && !string.IsNullOrWhiteSpace(UsuarioActual?.Password);
        }

        private async Task ExecuteLoginAsync()
        {
            await LoginAsync(UsuarioActual?.Email, UsuarioActual?.Password);
        }

        private void ExecuteLogout()
        {
            _sessionService.CerrarSesion();
            UsuarioActual = null;
            IdToken = string.Empty;
            MensajeError = string.Empty;
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }
    }

    // Mantener nombre de clase compatible con LoginPage
    public partial class AutenticacionViewModel
    {
        // Este bloque garantiza la compatibilidad de bindings del LoginPage rediseñado
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}