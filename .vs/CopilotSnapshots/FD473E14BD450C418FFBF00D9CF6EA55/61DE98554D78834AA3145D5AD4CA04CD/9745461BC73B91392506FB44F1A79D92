using System;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

namespace AutoLavadoApp.Services
{
    public class AuthService
    {
        private readonly HttpClient _httpClient;
        private readonly string _apiKey;

        public AuthService(HttpClient httpClient, string apiKey)
        {
            _httpClient = httpClient;
            _apiKey = apiKey;
        }

        public Task<AuthResult> LoginAsync(string email, string password)
        {
            var endpoint = $"https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={_apiKey}";
            return EnviarSolicitudAuthAsync(endpoint, email, password);
        }

        public Task<AuthResult> RegisterAsync(string email, string password)
        {
            var endpoint = $"https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={_apiKey}";
            return EnviarSolicitudAuthAsync(endpoint, email, password);
        }

        private async Task<AuthResult> EnviarSolicitudAuthAsync(string endpoint, string email, string password)
        {
            if (string.IsNullOrWhiteSpace(_apiKey))
            {
                return AuthResult.Error("Firebase API Key no está configurada.");
            }
            try
            {
                var payload = new
                {
                    email,
                    password,
                    returnSecureToken = true
                };

                var json = JsonSerializer.Serialize(payload);
                using var content = new StringContent(json, Encoding.UTF8, "application/json");
                using var response = await _httpClient.PostAsync(endpoint, content);
                var responseBody = await response.Content.ReadAsStringAsync();

                if (response.IsSuccessStatusCode)
                {
                    using var document = JsonDocument.Parse(responseBody);
                    var idToken = document.RootElement.TryGetProperty("idToken", out var idTokenElement)
                        ? idTokenElement.GetString() ?? string.Empty
                        : string.Empty;

                    var userId = document.RootElement.TryGetProperty("localId", out var localIdElement)
                        ? localIdElement.GetString() ?? string.Empty
                        : string.Empty;

                    if (string.IsNullOrWhiteSpace(idToken) || string.IsNullOrWhiteSpace(userId))
                    {
                        return AuthResult.Error("No se recibió información completa de Firebase.");
                    }

                    return AuthResult.Success(idToken, userId);
                }

                return AuthResult.Error(FirebaseErrorMapper.MapearErrorAuth(responseBody));
            }
            catch (Exception ex)
            {
                return AuthResult.Error(FirebaseErrorMapper.MapearExcepcion(ex, "No pudimos conectarnos con Firebase. Intenta nuevamente.").Message);
            }
        }
    }

    public sealed class AuthResult
    {
        private AuthResult(bool isSuccess, string idToken, string userId, string errorMessage)
        {
            IsSuccess = isSuccess;
            IdToken = idToken;
            UserId = userId;
            ErrorMessage = errorMessage;
        }

        public bool IsSuccess { get; }
        public string IdToken { get; }
        public string UserId { get; }
        public string ErrorMessage { get; }

        public static AuthResult Success(string idToken, string userId) => new AuthResult(true, idToken, userId, string.Empty);

        public static AuthResult Error(string errorMessage) => new AuthResult(false, string.Empty, string.Empty, errorMessage);
    }
}
