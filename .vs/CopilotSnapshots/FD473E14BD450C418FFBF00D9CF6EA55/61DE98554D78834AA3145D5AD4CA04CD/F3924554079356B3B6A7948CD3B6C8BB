using System;
using System.Collections.Generic;
using System.Linq;
using System.Net.Http;
using System.Text.Json;
using System.Threading.Tasks;
using AutoLavadoApp.Models;

namespace AutoLavadoApp.Services
{
    public class VehiculoService : FirestoreBaseService
    {
        private const string ColeccionVehiculos = "vehiculos";

        public VehiculoService(HttpClient httpClient, string apiKey)
            : base(httpClient, apiKey)
        {
        }

        public async Task<string> GuardarVehiculoAsync(
            string usuarioId,
            string marca,
            string modelo,
            int anio,
            string color,
            string placas,
            string tipo,
            string? idToken = null)
        {
            var placasNormalizadas = placas.Trim().ToUpperInvariant();
            var existe = await ExistePlacaAsync(usuarioId, placasNormalizadas, idToken);
            if (existe)
            {
                throw new FirebaseServiceException("Ya tienes un vehículo registrado con esas placas.", "DUPLICATE_PLATE");
            }

            var datos = new Dictionary<string, object>
            {
                { "usuarioId", usuarioId },
                { "clienteId", usuarioId },
                { "marca", marca },
                { "modelo", modelo },
                { "anio", anio },
                { "color", color },
                { "placas", placasNormalizadas },
                { "tipo", tipo }
            };

            return await CrearDocumentoAsync(ColeccionVehiculos, datos, idToken);
        }

        public async Task<List<Vehiculo>> ObtenerVehiculosPorClienteAsync(string clienteId, string? idToken = null)
        {
            var json = await ObtenerDocumentosAsync(ColeccionVehiculos, idToken);
            using var document = JsonDocument.Parse(json);

            var vehiculos = new List<Vehiculo>();
            if (!document.RootElement.TryGetProperty("documents", out var documentsElement) ||
                documentsElement.ValueKind != JsonValueKind.Array)
            {
                return vehiculos;
            }

            foreach (var doc in documentsElement.EnumerateArray())
            {
                if (!doc.TryGetProperty("fields", out var fields))
                {
                    continue;
                }

                var propietarioId = LeerString(fields, "usuarioId")
                    ?? LeerString(fields, "clienteId")
                    ?? string.Empty;
                if (!string.Equals(propietarioId, clienteId, StringComparison.Ordinal))
                {
                    continue;
                }

                vehiculos.Add(new Vehiculo
                {
                    Id = ObtenerIdDocumento(doc),
                    UsuarioId = propietarioId,
                    ClienteId = propietarioId,
                    Marca = LeerString(fields, "marca") ?? string.Empty,
                    Modelo = LeerString(fields, "modelo") ?? string.Empty,
                    Anio = LeerEntero(fields, "anio"),
                    Color = LeerString(fields, "color") ?? string.Empty,
                    Placas = LeerString(fields, "placas") ?? string.Empty,
                    Tipo = LeerString(fields, "tipo") ?? string.Empty
                });
            }

            return vehiculos
                .OrderBy(v => v.Marca)
                .ThenBy(v => v.Modelo)
                .ToList();
        }

        private async Task<bool> ExistePlacaAsync(string usuarioId, string placas, string? idToken)
        {
            var vehiculos = await ObtenerVehiculosPorClienteAsync(usuarioId, idToken);
            return vehiculos.Any(v => string.Equals(v.Placas, placas, StringComparison.OrdinalIgnoreCase));
        }

        public Task EliminarVehiculoAsync(string vehiculoId)
        {
            return EliminarDocumentoAsync(ColeccionVehiculos, vehiculoId);
        }

        private static string ObtenerIdDocumento(JsonElement documento)
        {
            if (!documento.TryGetProperty("name", out var nameElement))
            {
                return string.Empty;
            }

            var name = nameElement.GetString() ?? string.Empty;
            var partes = name.Split('/');
            return partes.Length == 0 ? string.Empty : partes[^1];
        }

        private static string? LeerString(JsonElement fields, string propiedad)
        {
            if (!fields.TryGetProperty(propiedad, out var propiedadElement))
            {
                return null;
            }

            if (!propiedadElement.TryGetProperty("stringValue", out var stringValueElement))
            {
                return null;
            }

            return stringValueElement.GetString();
        }

        private static int LeerEntero(JsonElement fields, string propiedad)
        {
            if (!fields.TryGetProperty(propiedad, out var propiedadElement))
            {
                return 0;
            }

            if (propiedadElement.TryGetProperty("integerValue", out var integerValueElement) &&
                int.TryParse(integerValueElement.GetString(), out var intValue))
            {
                return intValue;
            }

            if (propiedadElement.TryGetProperty("stringValue", out var stringValueElement) &&
                int.TryParse(stringValueElement.GetString(), out var intStringValue))
            {
                return intStringValue;
            }

            return 0;
        }
    }
}
