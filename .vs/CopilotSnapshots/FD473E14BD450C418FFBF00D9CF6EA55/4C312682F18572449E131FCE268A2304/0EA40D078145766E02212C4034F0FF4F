using System;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

namespace AutoLavadoApp.Services
{
    public class SessionService
    {
        private const string UidKey = "session_uid";
        private const string CorreoKey = "session_correo";
        private const string EmailKey = "session_email";
        private const string NombreKey = "session_nombre";
        private const string TokenKey = "session_token";
        private const string RolKey = "session_rol";

        public async Task GuardarSesionAsync(string uid, string correo, string token, string rol, string? nombre = null)
        {
            Preferences.Set(UidKey, uid ?? string.Empty);
            Preferences.Set(CorreoKey, correo ?? string.Empty);
            Preferences.Set(EmailKey, correo ?? string.Empty);
            Preferences.Set(NombreKey, nombre ?? string.Empty);
            Preferences.Set(RolKey, string.IsNullOrWhiteSpace(rol) ? "cliente" : rol);
            await SecureStorage.SetAsync(TokenKey, token ?? string.Empty);
        }

        public async Task<string> ObtenerTokenAsync()
        {
            return await SecureStorage.GetAsync(TokenKey) ?? string.Empty;
        }

        public string ObtenerUid()
        {
            return Preferences.Get(UidKey, string.Empty);
        }

        public string ObtenerEmail()
        {
            var correo = Preferences.Get(CorreoKey, string.Empty);
            if (!string.IsNullOrWhiteSpace(correo))
            {
                return correo;
            }

            return Preferences.Get(EmailKey, string.Empty);
        }

        public string ObtenerNombre()
        {
            return Preferences.Get(NombreKey, string.Empty);
        }

        public string ObtenerRol()
        {
            return Preferences.Get(RolKey, "cliente");
        }

        public async Task<bool> TieneSesionActivaAsync()
        {
            var uid = ObtenerUid();
            var token = await ObtenerTokenAsync();
            return !string.IsNullOrWhiteSpace(uid) && !TokenExpirado(token);
        }

        public static bool TokenExpirado(string? idToken)
        {
            if (string.IsNullOrWhiteSpace(idToken))
            {
                return true;
            }

            try
            {
                var partes = idToken.Split('.');
                if (partes.Length < 2)
                {
                    return true;
                }

                var payloadJson = DecodificarBase64Url(partes[1]);
                using var document = JsonDocument.Parse(payloadJson);

                if (!document.RootElement.TryGetProperty("exp", out var expElement))
                {
                    return true;
                }

                var exp = expElement.ValueKind switch
                {
                    JsonValueKind.Number when expElement.TryGetInt64(out var num) => num,
                    JsonValueKind.String when long.TryParse(expElement.GetString(), out var strNum) => strNum,
                    _ => 0L
                };

                if (exp <= 0)
                {
                    return true;
                }

                var expiracionUtc = DateTimeOffset.FromUnixTimeSeconds(exp);
                return expiracionUtc <= DateTimeOffset.UtcNow;
            }
            catch
            {
                return true;
            }
        }

        private static string DecodificarBase64Url(string base64Url)
        {
            var base64 = base64Url.Replace('-', '+').Replace('_', '/');
            switch (base64.Length % 4)
            {
                case 2:
                    base64 += "==";
                    break;
                case 3:
                    base64 += "=";
                    break;
            }

            var bytes = Convert.FromBase64String(base64);
            return Encoding.UTF8.GetString(bytes);
        }

        public void CerrarSesion()
        {
            Preferences.Remove(UidKey);
            Preferences.Remove(CorreoKey);
            Preferences.Remove(EmailKey);
            Preferences.Remove(NombreKey);
            Preferences.Remove(RolKey);
            SecureStorage.Remove(TokenKey);
        }

        public UserSession? SesionActual { get; private set; }

        public Task GuardarSesionAsync(string uid, string correo, string nombre, string rol, string idToken)
        {
            SesionActual = new UserSession
            {
                Uid = uid,
                Correo = correo,
                Nombre = nombre,
                Rol = string.IsNullOrWhiteSpace(rol) ? "cliente" : rol.ToLowerInvariant(),
                IdToken = idToken
            };

            return Task.CompletedTask;
        }

        public void LimpiarSesion() => SesionActual = null;
    }

    public class UserSession
    {
        public string Uid { get; set; } = string.Empty;
        public string Correo { get; set; } = string.Empty;
        public string Nombre { get; set; } = string.Empty;
        public string Rol { get; set; } = "cliente";
        public string IdToken { get; set; } = string.Empty;
    }
}
