<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoLavadoApp.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BrizzoLoginBlueDark}">

    <ScrollView>
        <Grid Padding="28,24,28,20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">

            <Image
                Grid.Row="0"
                Source="isotipo_brizzo.png"
                HeightRequest="34"
                WidthRequest="34"
                HorizontalOptions="Center"
                Margin="0,6,0,2" />

            <Image
                Grid.Row="1"
                Source="logo_brizzo.png"
                HeightRequest="52"
                HorizontalOptions="Center"
                Aspect="AspectFit"
                Margin="0,0,0,2" />

            <VerticalStackLayout Grid.Row="2" Spacing="4" Margin="0,4,0,6">
                <Label
                    Text="Bienvenido"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />
                <Label
                    Text="Inicia sesión para continuar"
                    FontSize="13"
                    TextColor="{StaticResource BrizzoLoginGraySoft}"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="3" Spacing="10" VerticalOptions="Start">

                <Border
                    StrokeThickness="1"
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 14">
                    <Entry
                        Placeholder="Correo electrónico"
                        Text="{Binding Correo}"
                        Keyboard="Email"
                        TextColor="White"
                        PlaceholderColor="{StaticResource BrizzoLoginGraySoft}"
                        HeightRequest="46"
                        Margin="14,0" />
                </Border>

                <Border
                    StrokeThickness="1"
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 14">
                    <Entry
                        Placeholder="Contraseña"
                        Text="{Binding Contrasena}"
                        IsPassword="True"
                        TextColor="White"
                        PlaceholderColor="{StaticResource BrizzoLoginGraySoft}"
                        HeightRequest="46"
                        Margin="14,0" />
                </Border>

                <Button
                    Text="Iniciar sesión"
                    Command="{Binding IniciarSesionCommand}"
                    HeightRequest="48"
                    CornerRadius="14"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="{StaticResource BrizzoLoginBlueBright}"
                    Margin="0,6,0,0" />

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,8,0,0">
                    <Label
                        Text="¿No tienes cuenta?"
                        FontSize="12"
                        TextColor="{StaticResource BrizzoLoginGraySoft}" />
                    <Label
                        Text="Regístrate"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="{StaticResource BrizzoLoginBlueBright}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrARegistroCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
