using System;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;
using AutoLavadoApp.Services;

namespace AutoLavadoApp.ViewModels
{
    public class MiCuentaViewModel : INotifyPropertyChanged
    {
        private readonly SessionService _sessionService;
        private readonly UsuarioService _usuarioService;

        private string _nombre = string.Empty;
        private string _correo = string.Empty;
        private string _rol = "cliente";
        private bool _isBusy;

        public event PropertyChangedEventHandler? PropertyChanged;

        public MiCuentaViewModel(SessionService sessionService, UsuarioService usuarioService)
        {
            _sessionService = sessionService;
            _usuarioService = usuarioService;

            IrMisVehiculosCommand = new Command(async () => await IrMisVehiculosAsync());
            IrMisCitasCommand = new Command(async () => await IrMisCitasAsync());
            EditarPerfilCommand = new Command(async () => await EditarPerfilAsync());
            ConfiguracionCommand = new Command(async () => await IrConfiguracionAsync());
            NotificacionesCommand = new Command(async () => await IrNotificacionesAsync());
            PrivacidadCommand = new Command(async () => await IrPrivacidadAsync());
            CerrarSesionCommand = new Command(async () => await CerrarSesionAsync(true), () => !IsBusy);
        }

        public ICommand IrMisVehiculosCommand { get; }
        public ICommand IrMisCitasCommand { get; }
        public ICommand EditarPerfilCommand { get; }
        public ICommand ConfiguracionCommand { get; }
        public ICommand NotificacionesCommand { get; }
        public ICommand PrivacidadCommand { get; }
        public ICommand CerrarSesionCommand { get; }

        public Func<string, string, string, Task>? MostrarAlertaAsync { get; set; }
        public Func<Task>? NavegarMisVehiculosAsync { get; set; }
        public Func<Task>? NavegarMisCitasAsync { get; set; }
        public Func<Task>? NavegarEditarPerfilAsync { get; set; }
        public Func<Task>? NavegarLoginAsync { get; set; }
        public Func<string, string, string, string, Task<bool>>? ConfirmarAccionAsync { get; set; }

        public string Nombre
        {
            get => _nombre;
            private set => SetProperty(ref _nombre, value);
        }

        public string Correo
        {
            get => _correo;
            private set => SetProperty(ref _correo, value);
        }

        public string Rol
        {
            get => _rol;
            private set
            {
                var normalized = string.IsNullOrWhiteSpace(value) ? "cliente" : value.ToLowerInvariant();
                if (SetProperty(ref _rol, normalized))
                {
                    OnPropertyChanged(nameof(RolMostrado));
                }
            }
        }

        public string RolMostrado => Rol switch
        {
            "admin" => "Administrador",
            "empleado" => "Empleado",
            _ => "Cliente"
        };

        // Alias de compatibilidad para bindings existentes
        public string NombreUsuario => Nombre;
        public string Email => Correo;
        public string RolUsuario => RolMostrado;

        public bool IsBusy
        {
            get => _isBusy;
            private set
            {
                if (SetProperty(ref _isBusy, value))
                {
                    ((Command)CerrarSesionCommand).ChangeCanExecute();
                }
            }
        }

        public async Task CargarPerfilAsync()
        {
            if (IsBusy)
            {
                return;
            }

            var uid = _sessionService.ObtenerUid();
            if (string.IsNullOrWhiteSpace(uid))
            {
                await CerrarSesionAsync(false);
                return;
            }

            try
            {
                IsBusy = true;

                var sesion = _sessionService.ObtenerSesionActual();
                if (sesion is null)
                {
                    Nombre = string.Empty;
                    Correo = string.Empty;
                    Rol = "cliente";
                    return;
                }

                Nombre = sesion.Nombre;
                Correo = sesion.Correo;
                Rol = sesion.Rol;

                // Fallback desde Firestore solo si rol no está bien definido.
                if (string.IsNullOrWhiteSpace(Rol) || Rol == "cliente")
                {
                    var idToken = await _sessionService.ObtenerTokenAsync();
                    var usuario = await _usuarioService.ObtenerUsuarioPorIdAsync(uid, idToken);
                    if (usuario is not null)
                    {
                        if (!string.IsNullOrWhiteSpace(usuario.Nombre)) Nombre = usuario.Nombre;
                        if (!string.IsNullOrWhiteSpace(usuario.Correo)) Correo = usuario.Correo;
                        Rol = string.IsNullOrWhiteSpace(usuario.Rol) ? Rol : usuario.Rol;
                    }
                }

                OnPropertyChanged(nameof(RolMostrado));
            }
            catch (FirebaseServiceException ex)
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", ex.Message, "OK");
                }
            }
            catch
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", "No fue posible cargar tu perfil. Intenta nuevamente.", "OK");
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        private async Task IrMisVehiculosAsync()
        {
            if (NavegarMisVehiculosAsync != null)
            {
                await NavegarMisVehiculosAsync();
            }
        }

        private async Task IrMisCitasAsync()
        {
            if (NavegarMisCitasAsync != null)
            {
                await NavegarMisCitasAsync();
            }
        }

        private async Task EditarPerfilAsync()
        {
            if (NavegarEditarPerfilAsync != null)
            {
                await NavegarEditarPerfilAsync();
                return;
            }

            if (MostrarAlertaAsync != null)
            {
                await MostrarAlertaAsync("Editar perfil", "Próximamente podrás editar tu perfil.", "OK");
            }
        }

        private async Task IrConfiguracionAsync()
        {
            if (MostrarAlertaAsync != null)
            {
                await MostrarAlertaAsync("Configuración", "Próximamente podrás personalizar tu configuración.", "OK");
            }
        }

        private async Task IrNotificacionesAsync()
        {
            if (MostrarAlertaAsync != null)
            {
                await MostrarAlertaAsync("Notificaciones", "Próximamente podrás gestionar tus notificaciones.", "OK");
            }
        }

        private async Task IrPrivacidadAsync()
        {
            if (MostrarAlertaAsync != null)
            {
                await MostrarAlertaAsync("Privacidad", "Próximamente podrás administrar tu privacidad.", "OK");
            }
        }

        private async Task CerrarSesionAsync(bool solicitarConfirmacion)
        {
            if (IsBusy)
            {
                return;
            }

            var confirmar = !solicitarConfirmacion
                || ConfirmarAccionAsync == null
                || await ConfirmarAccionAsync("Cerrar sesión", "¿Deseas cerrar sesión en BRIZZO?", "Cerrar sesión", "Cancelar");

            if (!confirmar)
            {
                return;
            }

            try
            {
                IsBusy = true;
                _sessionService.CerrarSesion();

                if (NavegarLoginAsync != null)
                {
                    await NavegarLoginAsync();
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }
}
