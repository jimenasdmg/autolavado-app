<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.MisCitasPage"
             Shell.NavBarIsVisible="False"
             Padding="0,18,0,0"
             BackgroundColor="#F5F7FB">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="20,24,20,10" Spacing="14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Button Text="←"
                        WidthRequest="52"
                        HeightRequest="52"
                        FontSize="20"
                        CornerRadius="16"
                        BackgroundColor="White"
                        TextColor="#0B1F4D"
                        Clicked="OnVolverClicked" />
                <Label Grid.Column="1"
                       Text="Mis citas"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D"
                       VerticalTextAlignment="Center" />
            </Grid>

            <Grid HorizontalOptions="End"
                  IsVisible="{Binding TieneNotificacionesNoLeidas}">
                <Border BackgroundColor="#DC2626"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 9"
                        WidthRequest="18"
                        HeightRequest="18"
                        HorizontalOptions="End">
                    <Label Text="{Binding NotificacionesNoLeidasTexto}"
                           FontSize="9"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Padding="20,0,20,20">
            <CollectionView ItemsSource="{Binding Citas}"
                            IsVisible="{Binding HasCitas}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                Stroke="#E7ECF4"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Border.Shadow>
                                <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Servicio}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           TextColor="#0B1F4D" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{Binding EstadoFondoColor}"
                                            Padding="10,5"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding Estado}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{Binding EstadoColor}" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                                    <Label Text="&#xF133;" FontFamily="FontAwesomeSolid" FontSize="12" VerticalTextAlignment="Center" TextColor="#3B82F6" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="#334155" />

                                    <Label Grid.Row="1" Text="&#xF017;" FontFamily="FontAwesomeSolid" FontSize="12" VerticalTextAlignment="Center" TextColor="#3B82F6" />
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Hora}"
                                           FontSize="14"
                                           TextColor="#334155" />

                                    <Label Grid.Row="2" Text="&#xF1B9;" FontFamily="FontAwesomeSolid" FontSize="12" VerticalTextAlignment="Center" TextColor="#3B82F6" />
                                    <Label Grid.Row="2" Grid.Column="1"
                                           Text="{Binding Vehiculo}"
                                           FontSize="14"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           TextColor="#334155" />

                                    <Label Grid.Row="3" Text="Método pago:" FontSize="12" TextColor="#64748B" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding MetodoPago}" FontSize="13" FontAttributes="Bold" TextColor="#334155" />
                                </Grid>

                                <Border BackgroundColor="#F8FAFC"
                                        Stroke="#E2E8F0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="Estado de tu servicio"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A" />

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="✔" TextColor="{Binding TrackAsignadoColor}" FontSize="12" />
                                            <Label Grid.Column="1" Text="Asignado" FontSize="12" TextColor="#334155" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="✔" TextColor="{Binding TrackEnCaminoColor}" FontSize="12" />
                                            <Label Grid.Column="1" Text="Empleado en camino" FontSize="12" TextColor="#334155" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="✔" TextColor="{Binding TrackRecogidoColor}" FontSize="12" />
                                            <Label Grid.Column="1" Text="Vehículo recogido" FontSize="12" TextColor="#334155" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="✔" TextColor="{Binding TrackLavadoColor}" FontSize="12" />
                                            <Label Grid.Column="1" Text="Lavado en progreso" FontSize="12" TextColor="#334155" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Text="✔" TextColor="{Binding TrackFinalizadoColor}" FontSize="12" />
                                            <Label Grid.Column="1" Text="Servicio finalizado" FontSize="12" TextColor="#334155" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <Button Text="Cancelar cita"
                                        HeightRequest="42"
                                        CornerRadius="10"
                                        BackgroundColor="#EF4444"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelarCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding PuedeCancelar}" />

                                <Button Text="Ver detalle"
                                        HeightRequest="42"
                                        CornerRadius="10"
                                        BackgroundColor="#0B1F4D"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout IsVisible="{Binding HasNoCitas}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="10">
                <Border BackgroundColor="White"
                        Stroke="#E7ECF4"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="20"
                        WidthRequest="290">
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="&#xF187;"
                               FontFamily="FontAwesomeSolid"
                               FontSize="40"
                               TextColor="#3B82F6"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Sin citas"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#0B1F4D"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding MensajeVacio}"
                               FontSize="14"
                               TextColor="#64748B"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Grid IsVisible="{Binding IsBusy}"
                  BackgroundColor="#80F5F7FB"
                  InputTransparent="False">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="#3B82F6"
                                       WidthRequest="42"
                                       HeightRequest="42" />
                    <Label Text="Sincronizando citas..."
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#0B1F4D" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
