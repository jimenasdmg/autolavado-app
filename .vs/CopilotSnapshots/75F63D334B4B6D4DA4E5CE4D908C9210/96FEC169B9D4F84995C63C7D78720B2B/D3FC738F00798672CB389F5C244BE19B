<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoLavadoApp.MiCuentaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mi cuenta"
    BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0B1020}">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Mi cuenta"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#0F172A" />

            <Border Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nombre" FontAttributes="Bold" TextColor="#334155" />
                    <Label Text="{Binding Nombre}" TextColor="#0F172A" />

                    <Label Text="Correo" FontAttributes="Bold" TextColor="#334155" Margin="0,8,0,0" />
                    <Label Text="{Binding Correo}" TextColor="#0F172A" />

                    <Label Text="Rol" FontAttributes="Bold" TextColor="#334155" Margin="0,8,0,0" />
                    <Label Text="{Binding Rol}" TextColor="#0F172A" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorDetalle}"
                   TextColor="#B91C1C"
                   IsVisible="{Binding TieneError}" />

            <Button Text="Configuración" />
            <Button Text="Cerrar sesión"
                    Command="{Binding CerrarSesionCommand}" />

        </VerticalStackLayout>
    </ScrollView>

    <Grid IsVisible="{Binding IsBusy}"
          BackgroundColor="#80F8FAFC"
          InputTransparent="False">
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#3B82F6" WidthRequest="42" HeightRequest="42" />
            <Label Text="Cargando cuenta..." FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
        </VerticalStackLayout>
    </Grid>
    </Grid>
</ContentPage>
