namespace AutoLavadoApp.ViewModels
{
    public class CitaViewModel : INotifyPropertyChanged
    {
        private int _siguienteId = 1;
        private readonly AutoLavadoApp.Services.Data.CitaService _citaService;
        private readonly AutoLavadoApp.Services.Core.SessionService _sessionService;

        public event PropertyChangedEventHandler? PropertyChanged;

        public CitaViewModel(AutoLavadoApp.Services.Data.CitaService citaService, AutoLavadoApp.Services.Core.SessionService sessionService)
        {
            _citaService = citaService;
            _sessionService = sessionService;
        }

        public ObservableCollection<Cita> Citas { get; } = new ObservableCollection<Cita>();

        public void AgendarCita(Cita cita)
        {
            if (cita == null)
            {
                return;
            }

            if (string.IsNullOrWhiteSpace(cita.Id))
            {
                cita.Id = _siguienteId++.ToString();
            }

            if (string.IsNullOrWhiteSpace(cita.Estado))
            {
                cita.Estado = "Agendada";
            }

            Citas.Add(cita);
            OnPropertyChanged(nameof(Citas));
        }

        public bool CancelarCita(int citaId)
        {
            var cita = Citas.FirstOrDefault(c => c.Id == citaId.ToString());
            if (cita == null)
            {
                return false;
            }

            cita.Estado = "Cancelada";
            OnPropertyChanged(nameof(Citas));
            return true;
        }

        public IEnumerable<Cita> ObtenerCitas()
        {
            return Citas;
        }

        public async Task CrearCitaAsync(string clienteId)
        {
            var idToken = await _sessionService.ObtenerTokenAsync();
            if (AutoLavadoApp.Services.Core.SessionService.TokenExpirado(idToken))
            {
                throw new UnauthorizedAccessException("El token de sesión expiró. Inicia sesión nuevamente.");
            }

            var cita = new Cita
            {
                Fecha = DateTime.UtcNow,
                Estado = "Agendada",
                UsuarioId = clienteId
            };

            await _citaService.CrearCitaAsync(cita, idToken);
        }

        private static bool EsErrorPermisos(Exception ex)
        {
            if (ex is HttpRequestException httpEx && httpEx.StatusCode == HttpStatusCode.Forbidden)
                return true;

            var texto = ex.ToString();
            return texto.Contains("403", StringComparison.OrdinalIgnoreCase)
                || texto.Contains("PERMISSION_DENIED", StringComparison.OrdinalIgnoreCase)
                || texto.Contains("Forbidden", StringComparison.OrdinalIgnoreCase)
                || texto.Contains("insufficient permissions", StringComparison.OrdinalIgnoreCase);
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }
    }
}

