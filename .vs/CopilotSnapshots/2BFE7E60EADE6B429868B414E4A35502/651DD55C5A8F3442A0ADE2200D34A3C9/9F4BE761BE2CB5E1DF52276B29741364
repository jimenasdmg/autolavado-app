<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F4F7">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24,36,24,28" Spacing="18">

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="🚘"
                       FontSize="48"
                       HorizontalTextAlignment="Center"
                       TextColor="#1E88E5" />
                <Label Text="BRIZZO"
                       FontSize="40"
                       FontAttributes="Bold"
                       TextColor="#0D1B3D"
                       CharacterSpacing="3"
                       HorizontalTextAlignment="Center" />
                <Label Text="AUTOLAVADO"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#1E88E5"
                       CharacterSpacing="4"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4" Margin="0,6,0,0">
                <Label Text="Iniciar sesión"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="#0D1B3D" />
                <Label Text="Bienvenido de nuevo"
                       FontSize="17"
                       TextColor="#616A82" />
                <Label Text="Inicia sesión para continuar"
                       FontSize="17"
                       TextColor="#616A82" />
            </VerticalStackLayout>

            <Border Stroke="#D8DEEA" StrokeThickness="1" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="14,6">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="✉" FontSize="16" VerticalTextAlignment="Center" TextColor="#7B849B" />
                    <Entry x:Name="EmailEntry"
                           Grid.Column="1"
                           Placeholder="Correo electrónico"
                           Keyboard="Email"
                           TextColor="#0D1B3D"
                           PlaceholderColor="#9AA2B8"
                           FontSize="16"
                           IsEnabled="{Binding CanInteract}" />
                </Grid>
            </Border>

            <Border Stroke="#D8DEEA" StrokeThickness="1" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="14,6">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="🔒" FontSize="16" VerticalTextAlignment="Center" TextColor="#7B849B" />
                    <Entry x:Name="PasswordEntry"
                           Grid.Column="1"
                           Placeholder="Contraseña"
                           IsPassword="True"
                           TextColor="#0D1B3D"
                           PlaceholderColor="#9AA2B8"
                           FontSize="16"
                           IsEnabled="{Binding CanInteract}" />
                </Grid>
            </Border>

            <Border BackgroundColor="#FEE2E2"
                    Stroke="#FCA5A5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="10"
                    IsVisible="{Binding HasError}">
                <Label Text="{Binding MensajeError}"
                       FontSize="14"
                       TextColor="#B91C1C" />
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="#EAF2FF"
                    StrokeShape="RoundRectangle 12"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="ℹ"
                           FontSize="20"
                           VerticalTextAlignment="Start"
                           TextColor="#1E88E5" />
                    <Label Grid.Column="1"
                           Text="Para agendar citas y acceder a nuestros servicios, necesitas tener una cuenta."
                           FontSize="15"
                           TextColor="#2F3B57" />
                </Grid>
            </Border>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <Label Text="¿Aún no tienes cuenta?"
                       FontSize="15"
                       TextColor="#707B96" />
                <Button Text="Crear cuenta"
                        Padding="0"
                        FontSize="15"
                        TextColor="#1E88E5"
                        BackgroundColor="Transparent"
                        IsEnabled="{Binding CanInteract}"
                        Clicked="OnIrCrearCuentaClicked" />
            </HorizontalStackLayout>

            <Button Text="Iniciar sesión"
                    HeightRequest="52"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#0D1B3D"
                    CornerRadius="12"
                    IsEnabled="{Binding CanInteract}"
                    Clicked="OnIniciarSesionClicked" />

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80F2F4F7"
              InputTransparent="False">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="#1E88E5"
                                   WidthRequest="42"
                                   HeightRequest="42" />
                <Label Text="Validando credenciales..."
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#0D1B3D" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
