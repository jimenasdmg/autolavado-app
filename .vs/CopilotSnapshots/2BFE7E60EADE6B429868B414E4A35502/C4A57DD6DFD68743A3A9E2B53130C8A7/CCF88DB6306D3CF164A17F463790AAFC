using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;
using AutoLavadoApp.Services;

namespace AutoLavadoApp.ViewModels
{
    public class AgendarCitaViewModel : INotifyPropertyChanged
    {
        private readonly CitaService _citaService;
        private readonly SessionService _sessionService;
        private readonly ServicioService _servicioService;
        private readonly VehiculoService _vehiculoService;

        private ServicioPickerItem? _servicioSeleccionado;
        private DateTime _fechaSeleccionada;
        private TimeSpan _horaSeleccionada;
        private Vehiculo? _vehiculoSeleccionado;
        private string _placas = string.Empty;
        private string _comentarios = string.Empty;

        private string _servicioError = string.Empty;
        private string _fechaError = string.Empty;
        private string _horaError = string.Empty;
        private string _placasError = string.Empty;
        private string _errorMessage = string.Empty;
        private bool _isBusy;

        public event PropertyChangedEventHandler? PropertyChanged;

        public AgendarCitaViewModel(CitaService citaService, SessionService sessionService, VehiculoService vehiculoService, ServicioService servicioService)
        {
            _citaService = citaService;
            _sessionService = sessionService;
            _vehiculoService = vehiculoService;
            _servicioService = servicioService;

            Servicios = new ObservableCollection<ServicioPickerItem>();

            FechaMinima = DateTime.Today;
            FechaSeleccionada = DateTime.Today;
            HoraSeleccionada = DateTime.Now.TimeOfDay;
            Vehiculos = new ObservableCollection<Vehiculo>();

            ConfirmarCitaCommand = new Command(async () => await ConfirmarCitaAsync(), () => !IsBusy);
        }

        public ObservableCollection<ServicioPickerItem> Servicios { get; }

        public ObservableCollection<Vehiculo> Vehiculos { get; }

        public DateTime FechaMinima { get; }

        public ICommand ConfirmarCitaCommand { get; }

        public Func<string, string, string, Task>? MostrarAlertaAsync { get; set; }

        public Func<Task>? NavegarAMisCitasAsync { get; set; }

        public ServicioPickerItem? ServicioSeleccionado
        {
            get => _servicioSeleccionado;
            set => SetProperty(ref _servicioSeleccionado, value);
        }

        public DateTime FechaSeleccionada
        {
            get => _fechaSeleccionada;
            set => SetProperty(ref _fechaSeleccionada, value);
        }

        public TimeSpan HoraSeleccionada
        {
            get => _horaSeleccionada;
            set => SetProperty(ref _horaSeleccionada, value);
        }

        public Vehiculo? VehiculoSeleccionado
        {
            get => _vehiculoSeleccionado;
            set
            {
                if (SetProperty(ref _vehiculoSeleccionado, value))
                {
                    Placas = value?.Placas ?? string.Empty;
                }
            }
        }

        public string Placas
        {
            get => _placas;
            set => SetProperty(ref _placas, value);
        }

        public string Comentarios
        {
            get => _comentarios;
            set => SetProperty(ref _comentarios, value);
        }

        public string ErrorMessage
        {
            get => _errorMessage;
            private set
            {
                if (SetProperty(ref _errorMessage, value))
                {
                    OnPropertyChanged(nameof(HasError));
                }
            }
        }

        public bool HasError => !string.IsNullOrWhiteSpace(ErrorMessage);

        public string ServicioError
        {
            get => _servicioError;
            private set
            {
                if (SetProperty(ref _servicioError, value))
                {
                    OnPropertyChanged(nameof(HasServicioError));
                }
            }
        }

        public bool HasServicioError => !string.IsNullOrWhiteSpace(ServicioError);

        public string FechaError
        {
            get => _fechaError;
            private set
            {
                if (SetProperty(ref _fechaError, value))
                {
                    OnPropertyChanged(nameof(HasFechaError));
                }
            }
        }

        public bool HasFechaError => !string.IsNullOrWhiteSpace(FechaError);

        public string HoraError
        {
            get => _horaError;
            private set
            {
                if (SetProperty(ref _horaError, value))
                {
                    OnPropertyChanged(nameof(HasHoraError));
                }
            }
        }

        public bool HasHoraError => !string.IsNullOrWhiteSpace(HoraError);

        public string PlacasError
        {
            get => _placasError;
            private set
            {
                if (SetProperty(ref _placasError, value))
                {
                    OnPropertyChanged(nameof(HasPlacasError));
                }
            }
        }

        public bool HasPlacasError => !string.IsNullOrWhiteSpace(PlacasError);

        public bool IsBusy
        {
            get => _isBusy;
            private set
            {
                if (SetProperty(ref _isBusy, value))
                {
                    OnPropertyChanged(nameof(CanInteract));
                    ((Command)ConfirmarCitaCommand).ChangeCanExecute();
                }
            }
        }

        public bool CanInteract => !IsBusy;

        public async Task CargarDatosAsync()
        {
            if (IsBusy)
            {
                return;
            }

            ErrorMessage = string.Empty;

            try
            {
                IsBusy = true;

                var uid = _sessionService.ObtenerUid();
                if (string.IsNullOrWhiteSpace(uid))
                {
                    Servicios.Clear();
                    Vehiculos.Clear();
                    VehiculoSeleccionado = null;
                    ServicioSeleccionado = null;
                    ErrorMessage = "Debes iniciar sesión para agendar una cita.";
                    return;
                }

                var idToken = await _sessionService.ObtenerTokenAsync();
                await CargarServiciosInternoAsync(idToken);
                await CargarVehiculosInternoAsync(uid, idToken);
            }
            catch (FirebaseServiceException ex)
            {
                ErrorMessage = ex.Message;
            }
            catch
            {
                ErrorMessage = "No fue posible cargar los datos para agendar la cita. Intenta nuevamente.";
            }
            finally
            {
                IsBusy = false;
            }
        }

        public async Task CargarVehiculosAsync()
        {
            if (IsBusy)
            {
                return;
            }

            ErrorMessage = string.Empty;

            try
            {
                IsBusy = true;

                var uid = _sessionService.ObtenerUid();
                if (string.IsNullOrWhiteSpace(uid))
                {
                    Vehiculos.Clear();
                    VehiculoSeleccionado = null;
                    Placas = string.Empty;
                    ErrorMessage = "Debes iniciar sesión para ver tus vehículos.";
                    return;
                }

                var idToken = await _sessionService.ObtenerTokenAsync();
                await CargarVehiculosInternoAsync(uid, idToken);
            }
            catch (FirebaseServiceException ex)
            {
                ErrorMessage = ex.Message;
            }
            catch
            {
                ErrorMessage = "No fue posible cargar tus vehículos. Intenta nuevamente.";
            }
            finally
            {
                IsBusy = false;
            }
        }

        private async Task ConfirmarCitaAsync()
        {
            if (IsBusy)
            {
                return;
            }

            LimpiarErrores();
            ErrorMessage = string.Empty;

            if (!ValidarCampos())
            {
                return;
            }

            try
            {
                IsBusy = true;

                var vehiculo = VehiculoSeleccionado?.NombreCompleto ?? string.Empty;

                var clienteId = _sessionService.ObtenerUid();
                if (string.IsNullOrWhiteSpace(clienteId))
                {
                    if (MostrarAlertaAsync != null)
                    {
                        await MostrarAlertaAsync("Sesión", "Debes iniciar sesión para agendar una cita.", "OK");
                    }
                    return;
                }

                var idToken = await _sessionService.ObtenerTokenAsync();

                await GuardarCitaAsync(clienteId, vehiculo, idToken);

                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Éxito", "Tu cita fue agendada correctamente.", "OK");
                }

                if (NavegarAMisCitasAsync != null)
                {
                    await NavegarAMisCitasAsync();
                }
            }
            catch
            {
                ErrorMessage = "No fue posible agendar la cita. Intenta nuevamente.";
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", "No fue posible agendar la cita. Intenta nuevamente.", "OK");
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        private bool ValidarCampos()
        {
            var esValido = true;

            if (ServicioSeleccionado == null)
            {
                ServicioError = "Selecciona un servicio.";
                esValido = false;
            }

            if (FechaSeleccionada < FechaMinima)
            {
                FechaError = "Selecciona una fecha.";
                esValido = false;
            }

            if (HoraSeleccionada == TimeSpan.Zero)
            {
                HoraError = "Selecciona una hora.";
                esValido = false;
            }

            if (string.IsNullOrWhiteSpace(Placas))
            {
                PlacasError = "Ingresa las placas del vehículo.";
                esValido = false;
            }

            if (VehiculoSeleccionado == null)
            {
                PlacasError = "Selecciona un vehículo registrado.";
                esValido = false;
            }

            return esValido;
        }

        private Task GuardarCitaAsync(string clienteId, string vehiculo, string idToken)
        {
            return _citaService.GuardarCitaAsync(
                usuarioId: clienteId,
                vehiculoId: VehiculoSeleccionado?.Id ?? string.Empty,
                servicioId: ServicioSeleccionado?.Id ?? string.Empty,
                fecha: FechaSeleccionada,
                hora: HoraSeleccionada,
                vehiculo: vehiculo,
                placas: Placas.Trim(),
                servicio: ServicioSeleccionado?.Nombre?.Trim() ?? string.Empty,
                comentarios: Comentarios?.Trim() ?? string.Empty,
                idToken: idToken);
        }

        private async Task CargarServiciosInternoAsync(string? idToken)
        {
            var servicios = await _servicioService.ObtenerServiciosActivosAsync(idToken);

            Servicios.Clear();
            foreach (var servicio in servicios)
            {
                if (string.IsNullOrWhiteSpace(servicio.Id) || string.IsNullOrWhiteSpace(servicio.Nombre))
                {
                    continue;
                }

                Servicios.Add(new ServicioPickerItem
                {
                    Id = servicio.Id,
                    Nombre = servicio.Nombre
                });
            }

            if (ServicioSeleccionado == null || !Servicios.Contains(ServicioSeleccionado))
            {
                ServicioSeleccionado = null;
            }
        }

        private async Task CargarVehiculosInternoAsync(string uid, string? idToken)
        {
            var vehiculos = await _vehiculoService.ObtenerVehiculosPorClienteAsync(uid, idToken);

            Vehiculos.Clear();
            foreach (var vehiculo in vehiculos)
            {
                Vehiculos.Add(vehiculo);
            }

            if (VehiculoSeleccionado == null || !Vehiculos.Contains(VehiculoSeleccionado))
            {
                VehiculoSeleccionado = null;
                Placas = string.Empty;
            }
        }

        public class ServicioPickerItem
        {
            public string Id { get; set; } = string.Empty;
            public string Nombre { get; set; } = string.Empty;

            public override string ToString()
            {
                return Nombre;
            }
        }

        private void LimpiarErrores()
        {
            ServicioError = string.Empty;
            FechaError = string.Empty;
            HoraError = string.Empty;
            PlacasError = string.Empty;
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }
}
