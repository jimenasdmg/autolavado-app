using System;
using System.Collections.Generic;
using System.Net;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

namespace AutoLavadoApp.Services
{
    public abstract class FirestoreBaseService
    {
        private const string ProjectId = "autolavadoapp-f9a62";
        private readonly HttpClient _httpClient;
        private readonly string _baseUrl;

        protected FirestoreBaseService(HttpClient httpClient, string apiKey)
        {
            _httpClient = httpClient;
            _baseUrl = $"https://firestore.googleapis.com/v1/projects/{ProjectId}/databases/(default)/documents";

            if (!_httpClient.DefaultRequestHeaders.Contains("X-Goog-Api-Key"))
            {
                _httpClient.DefaultRequestHeaders.Add("X-Goog-Api-Key", apiKey);
            }
        }

        protected async Task<string> CrearDocumentoAsync(string coleccion, Dictionary<string, object> datos)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}";
                var payload = new { fields = ConvertirAFormatoFirestore(datos) };
                var json = JsonSerializer.Serialize(payload);
                using var content = new StringContent(json, Encoding.UTF8, "application/json");

                using var response = await _httpClient.PostAsync(url, content);
                return await ValidarYLeerRespuestaAsync(response, "No fue posible guardar la información.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible guardar la información.");
            }
        }

        protected async Task<string> CrearODocumentoAsync(string coleccion, string documentoId, Dictionary<string, object> datos)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}/{documentoId}";
                var payload = new { fields = ConvertirAFormatoFirestore(datos) };
                var json = JsonSerializer.Serialize(payload);
                using var request = new HttpRequestMessage(HttpMethod.Patch, url)
                {
                    Content = new StringContent(json, Encoding.UTF8, "application/json")
                };

                using var response = await _httpClient.SendAsync(request);
                return await ValidarYLeerRespuestaAsync(response, "No fue posible guardar la información.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible guardar la información.");
            }
        }

        protected async Task<string> ObtenerDocumentosAsync(string coleccion)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}";
                using var response = await _httpClient.GetAsync(url);
                return await ValidarYLeerRespuestaAsync(response, "No fue posible cargar la información.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible cargar la información.");
            }
        }

        protected async Task<string?> ObtenerDocumentoAsync(string coleccion, string documentoId)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}/{documentoId}";
                using var response = await _httpClient.GetAsync(url);

                if (response.StatusCode == HttpStatusCode.NotFound)
                {
                    return null;
                }

                return await ValidarYLeerRespuestaAsync(response, "No fue posible obtener la información solicitada.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible obtener la información solicitada.");
            }
        }

        protected async Task<string> ActualizarDocumentoAsync(string coleccion, string documentoId, Dictionary<string, object> datos)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}/{documentoId}";
                var payload = new { fields = ConvertirAFormatoFirestore(datos) };
                var json = JsonSerializer.Serialize(payload);
                using var request = new HttpRequestMessage(HttpMethod.Patch, url)
                {
                    Content = new StringContent(json, Encoding.UTF8, "application/json")
                };

                using var response = await _httpClient.SendAsync(request);
                return await ValidarYLeerRespuestaAsync(response, "No fue posible actualizar la información.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible actualizar la información.");
            }
        }

        protected async Task EliminarDocumentoAsync(string coleccion, string documentoId)
        {
            try
            {
                var url = $"{_baseUrl}/{coleccion}/{documentoId}";
                using var response = await _httpClient.DeleteAsync(url);
                _ = await ValidarYLeerRespuestaAsync(response, "No fue posible eliminar la información.");
            }
            catch (Exception ex)
            {
                throw FirebaseErrorMapper.MapearExcepcion(ex, "No fue posible eliminar la información.");
            }
        }

        private static async Task<string> ValidarYLeerRespuestaAsync(HttpResponseMessage response, string defaultMessage)
        {
            var body = await response.Content.ReadAsStringAsync();
            if (response.IsSuccessStatusCode)
            {
                return body;
            }

            throw FirebaseErrorMapper.MapearErrorHttp(response.StatusCode, body, defaultMessage);
        }

        protected static Dictionary<string, object> ConvertirAFormatoFirestore(Dictionary<string, object> datos)
        {
            var fields = new Dictionary<string, object>();

            foreach (var item in datos)
            {
                fields[item.Key] = ConvertirValorFirestore(item.Value);
            }

            return fields;
        }

        protected static object ConvertirValorFirestore(object valor)
        {
            if (valor is string str)
            {
                return new Dictionary<string, object> { { "stringValue", str } };
            }

            if (valor is int i)
            {
                return new Dictionary<string, object> { { "integerValue", i.ToString() } };
            }

            if (valor is long l)
            {
                return new Dictionary<string, object> { { "integerValue", l.ToString() } };
            }

            if (valor is double d)
            {
                return new Dictionary<string, object> { { "doubleValue", d } };
            }

            if (valor is float f)
            {
                return new Dictionary<string, object> { { "doubleValue", f } };
            }

            if (valor is bool b)
            {
                return new Dictionary<string, object> { { "booleanValue", b } };
            }

            if (valor is DateTime dt)
            {
                return new Dictionary<string, object> { { "timestampValue", dt.ToUniversalTime().ToString("o") } };
            }

            if (valor is decimal dec)
            {
                return new Dictionary<string, object> { { "doubleValue", (double)dec } };
            }

            return new Dictionary<string, object> { { "stringValue", valor.ToString() ?? string.Empty } };
        }
    }
}
