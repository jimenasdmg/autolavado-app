using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using AutoLavadoApp.Services;

namespace AutoLavadoApp.ViewModels
{
    public class AdminViewModel : INotifyPropertyChanged
    {
        private readonly CitaService _citaService;
        private readonly EmpleadoService _empleadoService;
        private readonly ServicioService _servicioService;

        private int _citasHoy;
        private int _pendientes;
        private int _finalizadas;
        private int _empleadosActivos;
        private decimal _ingresosEstimados;
        private bool _isBusy;

        public event PropertyChangedEventHandler? PropertyChanged;

        public AdminViewModel(CitaService citaService, EmpleadoService empleadoService, ServicioService servicioService)
        {
            _citaService = citaService;
            _empleadoService = empleadoService;
            _servicioService = servicioService;

            Empleados = new ObservableCollection<EmpleadoAdminItem>();
            Servicios = new ObservableCollection<ServicioAdminItem>();
            CitasGlobales = new ObservableCollection<CitaAdminItem>();
        }

        public ObservableCollection<EmpleadoAdminItem> Empleados { get; }
        public ObservableCollection<ServicioAdminItem> Servicios { get; }
        public ObservableCollection<CitaAdminItem> CitasGlobales { get; }

        public Func<string, string, string, Task>? MostrarAlertaAsync { get; set; }
        public Func<string, string, string, string, string, Task<string?>>? SolicitarInputAsync { get; set; }

        public int CitasHoy
        {
            get => _citasHoy;
            private set => SetProperty(ref _citasHoy, value);
        }

        public int Pendientes
        {
            get => _pendientes;
            private set => SetProperty(ref _pendientes, value);
        }

        public int Finalizadas
        {
            get => _finalizadas;
            private set => SetProperty(ref _finalizadas, value);
        }

        public int EmpleadosActivos
        {
            get => _empleadosActivos;
            private set => SetProperty(ref _empleadosActivos, value);
        }

        public decimal IngresosEstimados
        {
            get => _ingresosEstimados;
            private set => SetProperty(ref _ingresosEstimados, value);
        }

        public string IngresosEstimadosTexto => $"${IngresosEstimados:N2}";

        public bool IsBusy
        {
            get => _isBusy;
            private set => SetProperty(ref _isBusy, value);
        }

        public async Task CargarDashboardAsync()
        {
            if (IsBusy)
            {
                return;
            }

            try
            {
                IsBusy = true;

                await CargarCitasGlobalesAsync();
                await CargarEmpleadosAsync();
                await CargarServiciosAsync();
                ActualizarResumen();
            }
            catch
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", "No fue posible cargar el panel administrador.", "OK");
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        public async Task AgregarEmpleadoAsync()
        {
            if (SolicitarInputAsync == null)
            {
                return;
            }

            var nombre = await SolicitarInputAsync("Nuevo empleado", "Nombre", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(nombre))
            {
                return;
            }

            var email = await SolicitarInputAsync("Nuevo empleado", "Correo", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(email))
            {
                return;
            }

            var empleadoId = Guid.NewGuid().ToString("N");
            await _empleadoService.CrearEmpleadoAsync(empleadoId, nombre.Trim(), email.Trim(), "empleado");
            await CargarEmpleadosAsync();
            ActualizarResumen();
        }

        public async Task CambiarRolEmpleadoAsync(EmpleadoAdminItem empleado)
        {
            if (empleado == null)
            {
                return;
            }

            var nuevoRol = empleado.Rol == "admin" ? "empleado" : "admin";
            await _empleadoService.ActualizarRolAsync(empleado.Id, nuevoRol);
            await CargarEmpleadosAsync();
        }

        public async Task CambiarEstadoEmpleadoAsync(EmpleadoAdminItem empleado)
        {
            if (empleado == null)
            {
                return;
            }

            await _empleadoService.ActualizarEstadoAsync(empleado.Id, !empleado.Activo);
            await CargarEmpleadosAsync();
            ActualizarResumen();
        }

        public async Task AgregarServicioAsync()
        {
            if (SolicitarInputAsync == null)
            {
                return;
            }

            var nombre = await SolicitarInputAsync("Nuevo servicio", "Nombre", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(nombre))
            {
                return;
            }

            var descripcion = await SolicitarInputAsync("Nuevo servicio", "Descripción", "Guardar", "Cancelar", "");
            if (string.IsNullOrWhiteSpace(descripcion))
            {
                return;
            }

            var precioRaw = await SolicitarInputAsync("Nuevo servicio", "Precio", "Guardar", "Cancelar", "");
            if (!decimal.TryParse(precioRaw, out var precio))
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Precio inválido", "Ingresa un precio numérico válido.", "OK");
                }
                return;
            }

            await _servicioService.CrearServicioAsync(nombre.Trim(), descripcion.Trim(), precio);
            await CargarServiciosAsync();
        }

        public async Task EditarServicioAsync(ServicioAdminItem servicio)
        {
            if (servicio == null || SolicitarInputAsync == null)
            {
                return;
            }

            var nuevoNombre = await SolicitarInputAsync("Editar servicio", "Nombre", "Guardar", "Cancelar", servicio.Nombre);
            if (string.IsNullOrWhiteSpace(nuevoNombre))
            {
                return;
            }

            var nuevaDescripcion = await SolicitarInputAsync("Editar servicio", "Descripción", "Guardar", "Cancelar", servicio.Descripcion);
            if (string.IsNullOrWhiteSpace(nuevaDescripcion))
            {
                return;
            }

            await _servicioService.EditarServicioAsync(servicio.Id, nuevoNombre.Trim(), nuevaDescripcion.Trim());
            await CargarServiciosAsync();
        }

        public async Task CambiarPrecioServicioAsync(ServicioAdminItem servicio)
        {
            if (servicio == null || SolicitarInputAsync == null)
            {
                return;
            }

            var precioRaw = await SolicitarInputAsync("Cambiar precio", "Nuevo precio", "Guardar", "Cancelar", servicio.Precio.ToString("N2"));
            if (!decimal.TryParse(precioRaw, out var nuevoPrecio))
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Precio inválido", "Ingresa un precio numérico válido.", "OK");
                }
                return;
            }

            await _servicioService.CambiarPrecioAsync(servicio.Id, nuevoPrecio);
            await CargarServiciosAsync();
        }

        public async Task CambiarEstadoServicioAsync(ServicioAdminItem servicio)
        {
            if (servicio == null)
            {
                return;
            }

            await _servicioService.CambiarEstadoAsync(servicio.Id, !servicio.Activo);
            await CargarServiciosAsync();
        }

        private async Task CargarCitasGlobalesAsync()
        {
            var citas = await _citaService.ObtenerTodasCitasAsync();
            CitasGlobales.Clear();

            foreach (var cita in citas)
            {
                CitasGlobales.Add(new CitaAdminItem
                {
                    ClienteId = cita.ClienteId,
                    Servicio = cita.Servicio,
                    Fecha = cita.Fecha,
                    Hora = cita.Hora,
                    Estado = cita.Estado,
                    Vehiculo = cita.Vehiculo,
                    Comentarios = cita.Comentarios
                });
            }
        }

        private async Task CargarEmpleadosAsync()
        {
            var empleados = await _empleadoService.ObtenerEmpleadosAsync();
            Empleados.Clear();

            foreach (var empleado in empleados)
            {
                Empleados.Add(new EmpleadoAdminItem
                {
                    Id = empleado.Id,
                    Nombre = empleado.Nombre,
                    Email = empleado.Email,
                    Rol = empleado.Rol,
                    Activo = empleado.Activo
                });
            }
        }

        private async Task CargarServiciosAsync()
        {
            var servicios = await _servicioService.ObtenerServiciosAsync();
            Servicios.Clear();

            foreach (var servicio in servicios)
            {
                Servicios.Add(new ServicioAdminItem
                {
                    Id = servicio.Id,
                    Nombre = servicio.Nombre,
                    Descripcion = servicio.Descripcion,
                    Precio = servicio.Precio,
                    Activo = servicio.Activo
                });
            }
        }

        private void ActualizarResumen()
        {
            var hoy = DateTime.Today;
            CitasHoy = 0;
            Pendientes = 0;
            Finalizadas = 0;
            IngresosEstimados = 0;

            foreach (var cita in CitasGlobales)
            {
                if (cita.Fecha.Date == hoy)
                {
                    CitasHoy++;
                }

                if (cita.Estado == "Pendiente")
                {
                    Pendientes++;
                }

                if (cita.Estado == "Finalizada")
                {
                    Finalizadas++;
                    IngresosEstimados += 250m;
                }
            }

            EmpleadosActivos = 0;
            foreach (var empleado in Empleados)
            {
                if (empleado.Activo)
                {
                    EmpleadosActivos++;
                }
            }

            OnPropertyChanged(nameof(IngresosEstimadosTexto));
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }

    public class EmpleadoAdminItem
    {
        public string Id { get; set; } = string.Empty;
        public string Nombre { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Rol { get; set; } = "empleado";
        public bool Activo { get; set; }

        public string EstadoTexto => Activo ? "Activo" : "Inactivo";
        public string EstadoColor => Activo ? "#16A34A" : "#B91C1C";
    }

    public class ServicioAdminItem
    {
        public string Id { get; set; } = string.Empty;
        public string Nombre { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public decimal Precio { get; set; }
        public bool Activo { get; set; }

        public string PrecioTexto => $"${Precio:N2}";
        public string EstadoTexto => Activo ? "Activo" : "Inactivo";
        public string EstadoColor => Activo ? "#16A34A" : "#B91C1C";
    }

    public class CitaAdminItem
    {
        public string ClienteId { get; set; } = string.Empty;
        public string Servicio { get; set; } = string.Empty;
        public DateTime Fecha { get; set; }
        public string Hora { get; set; } = string.Empty;
        public string Estado { get; set; } = string.Empty;
        public string Vehiculo { get; set; } = string.Empty;
        public string Comentarios { get; set; } = string.Empty;

        public string EstadoColor => Estado switch
        {
            "Pendiente" => "#F59E0B",
            "Confirmada" => "#2563EB",
            "En proceso" => "#7C3AED",
            "Finalizada" => "#16A34A",
            "Cancelada" => "#DC2626",
            _ => "#64748B"
        };
    }
}
