using AutoLavadoApp.ViewModels.Empleado;
using System.Diagnostics;

namespace AutoLavadoApp;

public partial class EmpleadoMensajesPage : ContentPage
{
    private readonly EmpleadoMensajesViewModel _viewModel;

    public EmpleadoMensajesPage()
    {
        InitializeComponent();

        _viewModel = IPlatformApplication.Current?.Services.GetService<EmpleadoMensajesViewModel>()
            ?? throw new InvalidOperationException("EmpleadoMensajesViewModel no está registrado en DI.");

        _viewModel.MostrarAlertaAsync = (titulo, mensaje, cancelar) => DisplayAlertAsync(titulo, mensaje, cancelar);

        BindingContext = _viewModel;
    }

    private async void OnEnviarClicked(object sender, EventArgs e)
    {
        if (BindingContext is not ViewModels.Empleado.EmpleadoMensajesViewModel vm) return;
        var ok = await vm.EnviarMensajeAsync();
        Debug.WriteLine($"[MENSAJES][EMPLEADO][UI][SEND] ok={ok}");
    }

    protected override async void OnAppearing()
    {
        base.OnAppearing();
        if (BindingContext is ViewModels.Empleado.EmpleadoMensajesViewModel vm)
        {
            await vm.RefrescarMensajesAsync();
        }
    }

    protected override void OnDisappearing()
    {
        base.OnDisappearing();
        if (BindingContext is ViewModels.Empleado.EmpleadoMensajesViewModel vm)
        {
            vm.DetenerPolling();
        }
    }

    private void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        if (e.PropertyName != nameof(EmpleadoMensajesViewModel.ScrollToLastRequest))
        {
            return;
        }

        var last = _viewModel.ScrollToLastRequest;
        if (last == null)
        {
            return;
        }

        MainThread.BeginInvokeOnMainThread(() => MensajesCollectionView.ScrollTo(last, position: ScrollToPosition.End, animate: true));
    }
}
