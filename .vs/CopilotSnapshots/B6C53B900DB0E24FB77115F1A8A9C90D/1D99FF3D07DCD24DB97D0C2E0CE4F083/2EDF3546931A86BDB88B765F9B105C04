<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoLavadoApp.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AutoLavadoApp.ViewModels.Auth"
    x:DataType="vm:AutenticacionViewModel"
    BackgroundColor="{StaticResource BrizzoLoginBlueDark}">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="14">

            <Image
                Grid.Row="0"
                Source="isotipo_brizzo.png"
                HeightRequest="42"
                HorizontalOptions="Center" />

            <Image
                Grid.Row="1"
                Source="logo_brizzo.png"
                HeightRequest="44"
                HorizontalOptions="Center" />

            <VerticalStackLayout Grid.Row="2" Spacing="4" Margin="0,8,0,0">
                <Label
                    Text="Bienvenido"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />
                <Label
                    Text="Inicia sesión para continuar"
                    FontSize="14"
                    TextColor="{StaticResource BrizzoLoginGraySoft}"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="3" Spacing="10" Margin="0,14,0,0">
                <Border
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,8">
                    <Entry
                        Placeholder="Correo electrónico"
                        Text="{Binding Email}"
                        Keyboard="Email"
                        TextColor="White"
                        PlaceholderColor="#A9B3C7"
                        ClearButtonVisibility="WhileEditing"
                        IsEnabled="{Binding CanInteract}" />
                </Border>

                <Label
                    Text="{Binding EmailError}"
                    FontSize="12"
                    TextColor="#FCA5A5"
                    Margin="2,-6,2,0"
                    IsVisible="{Binding HasEmailError}" />

                <Border
                    Stroke="{StaticResource BrizzoLoginInputStroke}"
                    BackgroundColor="{StaticResource BrizzoLoginInputBg}"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry
                            Placeholder="Contraseña"
                            Text="{Binding Password}"
                            IsPassword="{Binding IsPasswordHidden}"
                            TextColor="White"
                            PlaceholderColor="#A9B3C7"
                            IsEnabled="{Binding CanInteract}" />
                        <Button
                            Grid.Column="1"
                            Text="{Binding PasswordEyeIcon}"
                            FontFamily="FontAwesomeSolid"
                            BackgroundColor="Transparent"
                            TextColor="#A9B3C7"
                            Padding="4,0"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            IsEnabled="{Binding CanInteract}" />
                    </Grid>
                </Border>

                <Label
                    Text="{Binding PasswordError}"
                    FontSize="12"
                    TextColor="#FCA5A5"
                    Margin="2,-6,2,0"
                    IsVisible="{Binding HasPasswordError}" />

                <Label
                    Text="{Binding ErrorMessage}"
                    FontSize="13"
                    TextColor="#FCA5A5"
                    IsVisible="{Binding HasError}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="4" Spacing="10" Margin="0,14,0,0">
                <Button
                    Text="Iniciar sesión"
                    HeightRequest="46"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource BrizzoLoginBlueBright}"
                    TextColor="White"
                    FontAttributes="Bold"
                    IsEnabled="{Binding CanInteract}"
                    Clicked="OnIniciarSesionClicked" />

                <Button
                    Text="Crear cuenta"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    IsEnabled="{Binding CanInteract}"
                    Clicked="OnIrCrearCuentaClicked" />
            </VerticalStackLayout>

        </Grid>
    </ScrollView>

    <Grid IsVisible="{Binding IsBusy}"
          BackgroundColor="#660B1630"
          InputTransparent="False">
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="White"
                               WidthRequest="40"
                               HeightRequest="40" />
            <Label Text="Iniciando sesión..."
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
