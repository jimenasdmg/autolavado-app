rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    function isEmpleado() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'empleado';
    }

    function isCliente() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'cliente';
    }

    match /usuarios/{uid} {
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if isAdmin() ||
        (isSignedIn() &&
         request.auth.uid == uid &&
         request.resource.data.rol == resource.data.rol);
      allow delete: if isAdmin();
    }

    match /servicios/{servicioId} {
      allow read: if isAdmin() ||
        (isSignedIn() &&
         resource.data.activo == true &&
         (resource.data.visible == true || resource.data.visibleClientes == true));
      allow write: if isAdmin();
    }

    match /vehiculos/{vehiculoId} {
      allow create: if isSignedIn() &&
        (request.resource.data.usuarioId == request.auth.uid || isAdmin());
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      allow update: if isAdmin() ||
        (isSignedIn() &&
          resource.data.usuarioId == request.auth.uid &&
          request.resource.data.usuarioId == request.auth.uid);
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.usuarioId == request.auth.uid);
    }

    match /citas/{citaId} {
      allow create: if isSignedIn() &&
        (isAdmin() ||
         (isCliente() &&
          request.resource.data.clienteId == request.auth.uid &&
          request.resource.data.keys().hasAll([
            'id',
            'clienteId',
            'servicioId',
            'fecha',
            'hora',
            'estado',
            'modalidad'
          ]) &&
          request.resource.data.servicioId != '' &&
          request.resource.data.fecha != '' &&
          request.resource.data.hora != '' &&
          request.resource.data.modalidad != '' &&
          request.resource.data.estado in [
            'pendiente',
            'empleado_asignado',
            'en_camino',
            'vehiculo_recogido',
            'lavando',
            'finalizada',
            'entregada',
            'cancelada'
          ] &&
          request.resource.data.estado == 'pendiente' &&
          request.resource.data.empleadoId == ''));
      allow read: if isAdmin() ||
        (isCliente() && resource.data.clienteId == request.auth.uid) ||
        (isEmpleado() && (
          resource.data.estado == 'pendiente' ||
          resource.data.empleadoId == request.auth.uid));
      allow update: if isAdmin() ||
        (isCliente() &&
          resource.data.clienteId == request.auth.uid &&
          request.resource.data.clienteId == request.auth.uid &&
          request.resource.data.empleadoId == resource.data.empleadoId) ||
        (isEmpleado() && (
          (resource.data.estado == 'pendiente' &&
            request.resource.data.empleadoId == request.auth.uid &&
            request.resource.data.estado == 'empleado_asignado') ||
          (resource.data.empleadoId == request.auth.uid)) &&
          request.resource.data.clienteId == resource.data.clienteId &&
          request.resource.data.servicioId == resource.data.servicioId &&
          request.resource.data.fecha == resource.data.fecha &&
          request.resource.data.hora == resource.data.hora &&
          request.resource.data.precio == resource.data.precio);
      allow delete: if isAdmin();
    }

    match /notificaciones/{notificacionId} {
      allow create: if isAdmin() ||
        (isSignedIn() && request.resource.data.usuarioId == request.auth.uid);
      allow read, update: if isAdmin() ||
        (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /mensajes/{mensajeId} {
      allow create: if isSignedIn() &&
        (
          request.resource.data.emisorId == request.auth.uid ||
          request.resource.data.receptorId == request.auth.uid
        );

      allow read: if isSignedIn() &&
        (
          resource.data.emisorId == request.auth.uid ||
          resource.data.receptorId == request.auth.uid
        );

      allow update: if isSignedIn() &&
        (
          resource.data.receptorId == request.auth.uid
        );

      allow delete: if isAdmin();
    }
  }
}
