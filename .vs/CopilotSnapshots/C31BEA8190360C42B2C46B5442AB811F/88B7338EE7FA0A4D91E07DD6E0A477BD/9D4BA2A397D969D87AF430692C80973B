<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.AdminServiciosPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
                <Label Text="Servicios"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <Label Text="Administra catálogo y precios BRIZZO"
                       FontSize="14"
                       TextColor="#64748B" />

                <Button Text="Agregar servicio"
                        HeightRequest="44"
                        CornerRadius="12"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        ImageSource="{FontImageSource Glyph=&#xF067;, FontFamily=FontAwesomeSolid, Size=14, Color=White}"
                        ContentLayout="Left,8"
                        Clicked="OnAgregarServicioClicked" />

                <CollectionView ItemsSource="{Binding Servicios}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14"
                                    Margin="0,0,0,10">
                                <Border.Shadow>
                                    <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                        <Border WidthRequest="34"
                                                HeightRequest="34"
                                                BackgroundColor="#DBEAFE"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 17">
                                            <Label Text="{Binding ImagenVisual}"
                                                   FontFamily="FontAwesomeSolid"
                                                   FontSize="14"
                                                   TextColor="#1D4ED8"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>

                                        <Label Grid.Column="1" Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" VerticalTextAlignment="Center" />

                                        <Border Grid.Column="2" BackgroundColor="{Binding EstadoFondo}" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="9,4" HorizontalOptions="End">
                                            <Label Text="{Binding EstadoTexto}" FontSize="11" FontAttributes="Bold" TextColor="{Binding EstadoColor}" />
                                        </Border>

                                        <Border Grid.Column="3" BackgroundColor="{Binding VisibleFondo}" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="9,4" HorizontalOptions="End">
                                            <Label Text="{Binding VisibleTexto}" FontSize="11" FontAttributes="Bold" TextColor="{Binding VisibleColor}" />
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Descripcion}" FontSize="13" TextColor="#64748B" />
                                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                        <Label Text="{Binding PrecioTexto}" FontSize="13" FontAttributes="Bold" TextColor="#2563EB" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1" Text="{Binding DuracionTexto}" FontSize="12" FontAttributes="Bold" TextColor="#6366F1" VerticalTextAlignment="Center" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="Editar"
                                                HeightRequest="36"
                                                CornerRadius="10"
                                                BackgroundColor="#EFF6FF"
                                                TextColor="#1E40AF"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnEditarServicioClicked" />
                                        <Button Grid.Column="1"
                                                Text="Precio"
                                                HeightRequest="36"
                                                CornerRadius="10"
                                                BackgroundColor="#EDE9FE"
                                                TextColor="#6D28D9"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarPrecioServicioClicked" />
                                        <Button Grid.Column="2"
                                                Text="{Binding ToggleEstadoTexto}"
                                                HeightRequest="36"
                                                CornerRadius="10"
                                                BackgroundColor="#F1F5F9"
                                                TextColor="#334155"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarEstadoServicioClicked" />
                                    </Grid>

                                    <Button Text="{Binding ToggleVisibleTexto}"
                                            HeightRequest="36"
                                            CornerRadius="10"
                                            BackgroundColor="#EFF6FF"
                                            TextColor="#1E40AF"
                                            FontAttributes="Bold"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnCambiarVisibleServicioClicked" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
