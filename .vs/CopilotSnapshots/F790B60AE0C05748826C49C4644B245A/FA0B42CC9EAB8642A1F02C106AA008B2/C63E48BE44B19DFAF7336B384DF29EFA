using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;
using AutoLavadoApp.Services;

namespace AutoLavadoApp.ViewModels
{
    public class MisVehiculosViewModel : INotifyPropertyChanged
    {
        private readonly VehiculoService _vehiculoService;
        private readonly SessionService _sessionService;

        private bool _isBusy;
        private string _mensajeVacio = "No tienes vehículos registrados.";

        public event PropertyChangedEventHandler? PropertyChanged;

        public MisVehiculosViewModel(VehiculoService vehiculoService, SessionService sessionService)
        {
            _vehiculoService = vehiculoService;
            _sessionService = sessionService;
            Vehiculos = new ObservableCollection<Vehiculo>();
            CargarCommand = new Command(async () => await CargarVehiculosAsync(), () => !IsBusy);
        }

        public ObservableCollection<Vehiculo> Vehiculos { get; }

        public ICommand CargarCommand { get; }

        public Func<string, string, string, Task>? MostrarAlertaAsync { get; set; }

        public Func<string, string, string, string, Task<bool>>? ConfirmarAccionAsync { get; set; }

        public string MensajeVacio
        {
            get => _mensajeVacio;
            private set => SetProperty(ref _mensajeVacio, value);
        }

        public bool HasVehiculos => Vehiculos.Count > 0;

        public bool HasNoVehiculos => !HasVehiculos;

        public bool IsBusy
        {
            get => _isBusy;
            private set
            {
                if (SetProperty(ref _isBusy, value))
                {
                    ((Command)CargarCommand).ChangeCanExecute();
                }
            }
        }

        public async Task CargarVehiculosAsync()
        {
            if (IsBusy)
            {
                return;
            }

            try
            {
                IsBusy = true;

                var uid = _sessionService.ObtenerUid();
                if (string.IsNullOrWhiteSpace(uid))
                {
                    Vehiculos.Clear();
                    MensajeVacio = "Debes iniciar sesión para ver tus vehículos.";
                    OnPropertyChanged(nameof(HasVehiculos));
                    OnPropertyChanged(nameof(HasNoVehiculos));
                    return;
                }

                var vehiculos = await _vehiculoService.ObtenerVehiculosPorClienteAsync(uid);

                Vehiculos.Clear();
                foreach (var vehiculo in vehiculos)
                {
                    Vehiculos.Add(new Vehiculo
                    {
                        Id = vehiculo.Id,
                        ClienteId = vehiculo.ClienteId,
                        Marca = vehiculo.Marca,
                        Modelo = vehiculo.Modelo,
                        Color = vehiculo.Color,
                        Placas = vehiculo.Placas
                    });
                }

                MensajeVacio = Vehiculos.Count == 0
                    ? "Aún no tienes vehículos registrados."
                    : string.Empty;

                OnPropertyChanged(nameof(HasVehiculos));
                OnPropertyChanged(nameof(HasNoVehiculos));
            }
            catch
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", "No fue posible cargar tus vehículos.", "OK");
                }
            }
            finally
            {
                IsBusy = false;
            }
        }

        public async Task EliminarVehiculoAsync(Vehiculo? vehiculo)
        {
            if (vehiculo == null || string.IsNullOrWhiteSpace(vehiculo.Id))
            {
                return;
            }

            var confirmar = ConfirmarAccionAsync == null
                ? true
                : await ConfirmarAccionAsync("Eliminar vehículo", "¿Deseas eliminar este vehículo?", "Eliminar", "Cancelar");

            if (!confirmar)
            {
                return;
            }

            try
            {
                await _vehiculoService.EliminarVehiculoAsync(vehiculo.Id);

                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Vehículo eliminado", "El vehículo se eliminó correctamente.", "OK");
                }

                await CargarVehiculosAsync();
            }
            catch
            {
                if (MostrarAlertaAsync != null)
                {
                    await MostrarAlertaAsync("Error", "No fue posible eliminar el vehículo.", "OK");
                }
            }
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }
}
