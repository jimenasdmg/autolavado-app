<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.MisCitasPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="20,24,20,10" Spacing="14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Button Text="←"
                        WidthRequest="38"
                        HeightRequest="38"
                        FontSize="20"
                        CornerRadius="19"
                        BackgroundColor="White"
                        TextColor="#0B1F4D"
                        Clicked="OnVolverClicked" />
                <Label Grid.Column="1"
                       Text="Mis citas"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D"
                       VerticalTextAlignment="Center" />
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Padding="20,0,20,20">
            <CollectionView ItemsSource="{Binding Citas}"
                            IsVisible="{Binding HasCitas}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                Stroke="#E7ECF4"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Border.Shadow>
                                <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Servicio}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#0B1F4D" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{Binding EstadoFondoColor}"
                                            Padding="10,5"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding Estado}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{Binding EstadoColor}" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                                    <Label Text="📅" FontSize="14" VerticalTextAlignment="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="#334155" />

                                    <Label Grid.Row="1" Text="🕒" FontSize="14" VerticalTextAlignment="Center" />
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Hora}"
                                           FontSize="14"
                                           TextColor="#334155" />

                                    <Label Grid.Row="2" Text="🚗" FontSize="14" VerticalTextAlignment="Center" />
                                    <Label Grid.Row="2" Grid.Column="1"
                                           Text="{Binding Vehiculo}"
                                           FontSize="14"
                                           TextColor="#334155" />
                                </Grid>

                                <Button Text="Cancelar cita"
                                        HeightRequest="42"
                                        CornerRadius="10"
                                        BackgroundColor="#EF4444"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Command="{Binding CancelarCommand}"
                                        IsVisible="{Binding PuedeCancelar}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout IsVisible="{Binding HasCitas, Converter={StaticResource InverseBooleanConverter}}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                <Label Text="📭" FontSize="36" HorizontalTextAlignment="Center" />
                <Label Text="{Binding MensajeVacio}"
                       FontSize="15"
                       TextColor="#64748B"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
