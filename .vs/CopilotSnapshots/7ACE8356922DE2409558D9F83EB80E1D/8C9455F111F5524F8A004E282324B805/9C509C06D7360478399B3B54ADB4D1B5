using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;

namespace AutoLavadoApp.ViewModels
{
    public class AutenticacionViewModel : INotifyPropertyChanged
    {
        private Usuario? _usuarioActual;
        private string _email = string.Empty;
        private string _password = string.Empty;
        private bool _estaAutenticado;
        private string _mensajeError = string.Empty;

        public event PropertyChangedEventHandler? PropertyChanged;

        public AutenticacionViewModel()
        {
            LoginCommand = new Command(async () => await ExecuteLoginAsync(), () => CanLogin());
            LogoutCommand = new Command(ExecuteLogout, () => EstaAutenticado);
        }

        public Usuario? UsuarioActual
        {
            get => _usuarioActual;
            private set
            {
                if (_usuarioActual != value)
                {
                    _usuarioActual = value;
                    OnPropertyChanged();
                    EstaAutenticado = value != null;
                }
            }
        }

        public string Email
        {
            get => _email;
            set
            {
                if (_email != value)
                {
                    _email = value;
                    OnPropertyChanged();
                    ((Command)LoginCommand).ChangeCanExecute();
                }
            }
        }

        public string Password
        {
            get => _password;
            set
            {
                if (_password != value)
                {
                    _password = value;
                    OnPropertyChanged();
                    ((Command)LoginCommand).ChangeCanExecute();
                }
            }
        }

        public bool EstaAutenticado
        {
            get => _estaAutenticado;
            private set
            {
                if (_estaAutenticado != value)
                {
                    _estaAutenticado = value;
                    OnPropertyChanged();
                    ((Command)LogoutCommand).ChangeCanExecute();
                }
            }
        }

        public string MensajeError
        {
            get => _mensajeError;
            private set
            {
                if (_mensajeError != value)
                {
                    _mensajeError = value;
                    OnPropertyChanged();
                }
            }
        }

        public ICommand LoginCommand { get; }
        public ICommand LogoutCommand { get; }

        public bool Login(string? email, string? password)
        {
            MensajeError = string.Empty;

            Email = email ?? string.Empty;
            Password = password ?? string.Empty;

            if (Email == "admin@test.com" && Password == "123")
            {
                UsuarioActual = new Usuario
                {
                    Id = 1,
                    Email = Email,
                    Nombre = "Administrador",
                    Password = string.Empty
                };

                Password = string.Empty;
                return true;
            }

            MensajeError = "Credenciales incorrectas. Intenta con admin@test.com / 123";
            return false;
        }

        public void Logout()
        {
            ExecuteLogout();
        }

        private bool CanLogin()
        {
            return !string.IsNullOrWhiteSpace(Email) && !string.IsNullOrWhiteSpace(Password);
        }

        private async Task ExecuteLoginAsync()
        {
            MensajeError = string.Empty;

            await Task.Delay(500);

            if (Email == "admin@test.com" && Password == "123")
            {
                UsuarioActual = new Usuario
                {
                    Id = 1,
                    Email = Email,
                    Nombre = "Administrador",
                    Password = string.Empty
                };

                Email = string.Empty;
                Password = string.Empty;
            }
            else
            {
                MensajeError = "Credenciales incorrectas. Intenta con admin@test.com / 123";
            }
        }

        private void ExecuteLogout()
        {
            UsuarioActual = null;
            Email = string.Empty;
            Password = string.Empty;
            MensajeError = string.Empty;
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }
    }
}