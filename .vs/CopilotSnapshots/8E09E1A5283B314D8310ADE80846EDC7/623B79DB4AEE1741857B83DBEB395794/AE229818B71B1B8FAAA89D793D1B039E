using AutoLavadoApp.Services;
using AutoLavadoApp.ViewModels;
using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Threading.Tasks;

namespace AutoLavadoApp.ViewModels
{
    public class DetalleCitaViewModel : INotifyPropertyChanged
    {
        private readonly CitaService _citaService;
        private readonly ObservacionService _observacionService;
        private readonly SessionService _sessionService;

        private string _citaId = string.Empty;
        private string _vehiculo = string.Empty;
        private string _servicio = string.Empty;
        private DateTime _fecha;
        private string _hora = string.Empty;
        private string _estado = string.Empty;
        private bool _isBusy;

        public event PropertyChangedEventHandler? PropertyChanged;

        public DetalleCitaViewModel(CitaService citaService, ObservacionService observacionService, SessionService sessionService)
        {
            _citaService = citaService;
            _observacionService = observacionService;
            _sessionService = sessionService;
            Observaciones = new ObservableCollection<ObservacionTimelineItem>();
        }

        public ObservableCollection<ObservacionTimelineItem> Observaciones { get; }

        public string CitaId
        {
            get => _citaId;
            private set => SetProperty(ref _citaId, value);
        }

        public string Vehiculo
        {
            get => _vehiculo;
            private set => SetProperty(ref _vehiculo, value);
        }

        public string Servicio
        {
            get => _servicio;
            private set => SetProperty(ref _servicio, value);
        }

        public DateTime Fecha
        {
            get => _fecha;
            private set => SetProperty(ref _fecha, value);
        }

        public string Hora
        {
            get => _hora;
            private set => SetProperty(ref _hora, value);
        }

        public string Estado
        {
            get => _estado;
            private set
            {
                if (SetProperty(ref _estado, value))
                {
                    OnPropertyChanged(nameof(EstadoColor));
                    OnPropertyChanged(nameof(EstadoFondoColor));
                }
            }
        }

        public string EstadoColor => Estado switch
        {
            "Pendiente" => "#F59E0B",
            "Confirmada" => "#2563EB",
            "En proceso" => "#7C3AED",
            "Finalizada" => "#16A34A",
            "Cancelada" => "#DC2626",
            _ => "#64748B"
        };

        public string EstadoFondoColor => Estado switch
        {
            "Pendiente" => "#FEF3C7",
            "Confirmada" => "#DBEAFE",
            "En proceso" => "#EDE9FE",
            "Finalizada" => "#DCFCE7",
            "Cancelada" => "#FEE2E2",
            _ => "#E2E8F0"
        };

        public bool HasObservaciones => Observaciones.Count > 0;

        public bool HasNoObservaciones => !HasObservaciones;

        public bool IsBusy
        {
            get => _isBusy;
            private set => SetProperty(ref _isBusy, value);
        }

        public async Task CargarDetalleAsync(string citaId)
        {
            if (string.IsNullOrWhiteSpace(citaId) || IsBusy)
            {
                return;
            }

            try
            {
                IsBusy = true;

                var idToken = await _sessionService.ObtenerTokenAsync();
                if (SessionService.TokenExpirado(idToken))
                {
                    throw new UnauthorizedAccessException("El token de sesión expiró. Inicia sesión nuevamente.");
                }

                var citas = await _citaService.ObtenerTodasCitasAsync(idToken);
                var cita = citas.Find(c => c.Id == citaId);
                if (cita == null)
                {
                    return;
                }

                CitaId = cita.Id;
                Vehiculo = cita.VehiculoId;
                Servicio = cita.ServicioId;
                Fecha = cita.Fecha;
                Hora = cita.Hora;
                Estado = cita.Estado;

                var observaciones = await _observacionService.ObtenerObservacionesPorCitaAsync(citaId);
                Observaciones.Clear();
                foreach (var observacion in observaciones)
                {
                    Observaciones.Add(new ObservacionTimelineItem
                    {
                        Comentario = observacion.Comentario,
                        EmpleadoId = observacion.EmpleadoId,
                        Fecha = observacion.Fecha
                    });
                }

                OnPropertyChanged(nameof(HasObservaciones));
                OnPropertyChanged(nameof(HasNoObservaciones));
            }
            finally
            {
                IsBusy = false;
            }
        }

        protected virtual void OnPropertyChanged([CallerMemberName] string? propertyName = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }

        private bool SetProperty<T>(ref T storage, T value, [CallerMemberName] string? propertyName = null)
        {
            if (Equals(storage, value))
            {
                return false;
            }

            storage = value;
            OnPropertyChanged(propertyName);
            return true;
        }
    }

    public class ObservacionTimelineItem
    {
        public string Comentario { get; set; } = string.Empty;
        public string EmpleadoId { get; set; } = string.Empty;
        public DateTime Fecha { get; set; }
        public string FechaTexto => Fecha.ToString("dd/MM/yyyy HH:mm");
    }
}
