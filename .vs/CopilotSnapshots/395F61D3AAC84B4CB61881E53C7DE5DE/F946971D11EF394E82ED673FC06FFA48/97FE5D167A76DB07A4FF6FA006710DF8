<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.AdminMensajesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="10">
        <Label Text="Mensajes internos"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="#0B1F4D" />

        <Grid Grid.Row="1" ColumnDefinitions="1.2*,2*" ColumnSpacing="12">
            <Border BackgroundColor="White"
                    Stroke="#E7ECF4"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Conversaciones"
                           FontAttributes="Bold"
                           TextColor="#0B1F4D" />

                    <CollectionView x:Name="ConversacionesCollection"
                                    ItemsSource="{Binding Conversaciones}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnConversacionSeleccionada">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#F8FAFC"
                                        Stroke="#E7ECF4"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                        <Label Text="{Binding EmpleadoNombre}"
                                               FontAttributes="Bold"
                                               FontSize="13"
                                               TextColor="#0B1F4D" />
                                        <Label Grid.Column="1"
                                               Text="{Binding FechaUltimoMensaje, StringFormat='{0:HH:mm}'}"
                                               FontSize="11"
                                               TextColor="#64748B" />

                                        <Label Grid.Row="1"
                                               Text="{Binding UltimoMensaje}"
                                               FontSize="12"
                                               TextColor="#475569"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <Border Grid.Row="1"
                                                Grid.Column="1"
                                                WidthRequest="10"
                                                HeightRequest="10"
                                                BackgroundColor="#DC2626"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 5"
                                                IsVisible="{Binding TieneNoLeidos}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1"
                    BackgroundColor="White"
                    Stroke="#E7ECF4"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    Padding="10">
                <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8">
                    <Label Text="{Binding ConversacionActualTitulo}"
                           FontAttributes="Bold"
                           TextColor="#0B1F4D" />

                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding MensajesActuales}" Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{Binding Fondo}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="10"
                                            HorizontalOptions="{Binding Alineacion}">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding Mensaje}" TextColor="{Binding ColorTexto}" FontSize="13" />
                                            <Label Text="{Binding Fecha, StringFormat='{0:dd/MM HH:mm}'}"
                                                   TextColor="{Binding ColorTexto}"
                                                   Opacity="0.8"
                                                   FontSize="10" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Entry Grid.Row="2"
                           Placeholder="Escribe tu respuesta"
                           Text="{Binding MensajeNuevo}"
                           MaxLength="500"
                           IsEnabled="{Binding TieneConversacionSeleccionada}" />

                    <Button Grid.Row="3"
                            Text="Enviar"
                            HeightRequest="42"
                            CornerRadius="10"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            Command="{Binding EnviarMensajeCommand}"
                            IsEnabled="{Binding TieneConversacionSeleccionada}" />
                </Grid>
            </Border>
        </Grid>

        <Label Grid.Row="2"
               Text="{Binding ErrorDetalle}"
               TextColor="#B91C1C"
               IsVisible="{Binding TieneError}" />
    </Grid>
</ContentPage>
