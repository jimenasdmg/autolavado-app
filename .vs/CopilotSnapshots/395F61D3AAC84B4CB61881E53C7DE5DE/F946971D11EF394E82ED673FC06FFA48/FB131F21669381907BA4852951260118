<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.ConfiguracionPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="18,16,18,20" Spacing="12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Button Text="←"
                            WidthRequest="38"
                            HeightRequest="38"
                            FontSize="20"
                            CornerRadius="19"
                            BackgroundColor="White"
                            TextColor="#0B1F4D"
                            Clicked="OnVolverClicked" />
                    <Label Grid.Column="1"
                           Text="Configuración"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#0B1F4D"
                           VerticalTextAlignment="Center" />
                </Grid>

                <Border BackgroundColor="White" Stroke="#E7ECF4" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Perfil" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" />
                        <Entry Placeholder="Nombre" Text="{Binding Nombre}" IsEnabled="{Binding PuedeEditarPerfil}" />
                        <Entry Placeholder="Teléfono (10 dígitos)" Keyboard="Telephone" MaxLength="10" Text="{Binding Telefono}" IsEnabled="{Binding PuedeEditarPerfil}" />
                        <Button Text="Guardar cambios"
                                HeightRequest="42"
                                CornerRadius="10"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                IsEnabled="{Binding PuedeEditarPerfil}"
                                Command="{Binding GuardarPerfilCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#E7ECF4" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Preferencias" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" />
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Text="Modo oscuro (próximamente)" TextColor="#334155" VerticalTextAlignment="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding TemaOscuro}" IsEnabled="False" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Text="Notificaciones" TextColor="#334155" VerticalTextAlignment="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding NotificacionesActivas}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#E7ECF4" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12" IsVisible="{Binding EsAdmin}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Gestión del sistema" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" />
                        <Button Text="Información de Firebase"
                                HeightRequest="40"
                                CornerRadius="10"
                                BackgroundColor="#EFF6FF"
                                TextColor="#1E40AF"
                                Command="{Binding InfoFirebaseCommand}" />
                        <Button Text="Cerrar todas las sesiones"
                                HeightRequest="40"
                                CornerRadius="10"
                                BackgroundColor="#F1F5F9"
                                TextColor="#475569"
                                IsEnabled="False" />
                        <Label Text="Próximamente" TextColor="#64748B" FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" Stroke="#E7ECF4" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Cuenta" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" />
                        <Button Text="Cambiar contraseña" HeightRequest="40" CornerRadius="10" BackgroundColor="#EFF6FF" TextColor="#1E40AF" Command="{Binding CambiarPasswordCommand}" />
                        <Button Text="Cerrar sesión" HeightRequest="40" CornerRadius="10" BorderWidth="1" BorderColor="#FCA5A5" BackgroundColor="Transparent" TextColor="#B91C1C" Command="{Binding CerrarSesionCommand}" />
                        <Label Text="{Binding VersionApp, StringFormat='Versión {0}'}" TextColor="#64748B" FontSize="12" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ErrorDetalle}" TextColor="#B91C1C" IsVisible="{Binding TieneError}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
