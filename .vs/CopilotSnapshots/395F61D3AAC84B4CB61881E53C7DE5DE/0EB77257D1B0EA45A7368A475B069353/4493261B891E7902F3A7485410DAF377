<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.AdminEmpleadosPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
                <Label Text="Empleados"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <Label Text="Gestiona el equipo BRIZZO"
                       FontSize="14"
                       TextColor="#64748B" />

                <Button Text="Agregar empleado"
                        HeightRequest="44"
                        CornerRadius="12"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        ImageSource="{FontImageSource Glyph=&#xF234;, FontFamily=FontAwesomeSolid, Size=14, Color=White}"
                        ContentLayout="Left,8"
                        Clicked="OnAgregarEmpleadoClicked" />

                <Button Text="Mensajes internos"
                        HeightRequest="42"
                        CornerRadius="12"
                        BackgroundColor="#EFF6FF"
                        TextColor="#1E40AF"
                        FontAttributes="Bold"
                        ImageSource="{FontImageSource Glyph=&#xF086;, FontFamily=FontAwesomeSolid, Size=14, Color=#1E40AF}"
                        ContentLayout="Left,8"
                        Clicked="OnAbrirMensajesClicked" />

                <CollectionView ItemsSource="{Binding Empleados}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding NombreCompleto}" FontSize="16" FontAttributes="Bold" TextColor="#0B1F4D" />
                                    <Label Text="{Binding Email}" FontSize="13" TextColor="#64748B" />
                                    <Label Text="{Binding Telefono}" FontSize="12" TextColor="#64748B" />
                                    <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                                        <Label Text="{Binding EstadoTexto}" FontSize="12" TextColor="{Binding EstadoColor}" VerticalTextAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Text="Cambiar rol"
                                                HeightRequest="36"
                                                CornerRadius="10"
                                                BackgroundColor="#EFF6FF"
                                                TextColor="#1E40AF"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarRolEmpleadoClicked" />
                                        <Button Grid.Column="2"
                                                Text="Activar/Desactivar"
                                                HeightRequest="36"
                                                CornerRadius="10"
                                                BackgroundColor="#F1F5F9"
                                                TextColor="#334155"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnCambiarEstadoEmpleadoClicked" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
