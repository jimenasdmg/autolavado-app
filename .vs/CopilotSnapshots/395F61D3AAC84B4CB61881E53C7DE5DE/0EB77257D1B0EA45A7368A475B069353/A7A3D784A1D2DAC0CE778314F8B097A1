using System.Text.Json;
using AutoLavadoApp.Models;
using AutoLavadoApp.Services.Core;

namespace AutoLavadoApp.Services.Data;

public class MensajeInternoService : FirestoreBaseService
{
    private const string Collection = "mensajes";

    public MensajeInternoService(HttpClient httpClient) : base(httpClient)
    {
    }

    public async Task<bool> EnviarMensajeAsync(MensajeInterno mensaje, string idToken)
    {
        if (string.IsNullOrWhiteSpace(idToken) || string.IsNullOrWhiteSpace(mensaje.RemitenteUid) || string.IsNullOrWhiteSpace(mensaje.DestinatarioUid) || string.IsNullOrWhiteSpace(mensaje.Mensaje))
        {
            return false;
        }

        var id = string.IsNullOrWhiteSpace(mensaje.Id) ? Guid.NewGuid().ToString("N") : mensaje.Id;
        var fechaUtc = mensaje.Fecha == default ? DateTime.UtcNow : mensaje.Fecha.ToUniversalTime();

        var body = new
        {
            fields = new Dictionary<string, object>
            {
                ["id"] = new { stringValue = id },
                ["remitenteUid"] = new { stringValue = mensaje.RemitenteUid },
                ["remitenteNombre"] = new { stringValue = mensaje.RemitenteNombre ?? string.Empty },
                ["destinatarioUid"] = new { stringValue = mensaje.DestinatarioUid },
                ["destinatarioNombre"] = new { stringValue = mensaje.DestinatarioNombre ?? string.Empty },
                ["mensaje"] = new { stringValue = mensaje.Mensaje.Trim() },
                ["fecha"] = new { timestampValue = fechaUtc.ToString("O") },
                ["leido"] = new { booleanValue = mensaje.Leido }
            }
        };

        return await CrearDocumentoAsync(Collection, body, id, idToken);
    }

    public async Task<List<MensajeInterno>> ObtenerMensajesPorUsuarioAsync(string uid, string idToken)
    {
        if (string.IsNullOrWhiteSpace(uid) || string.IsNullOrWhiteSpace(idToken))
        {
            return new List<MensajeInterno>();
        }

        var doc = await ObtenerColeccionAsync(Collection, idToken);
        if (doc is null || !doc.Value.TryGetProperty("documents", out var documents) || documents.ValueKind != JsonValueKind.Array)
        {
            return new List<MensajeInterno>();
        }

        var mensajes = new List<MensajeInterno>();
        foreach (var d in documents.EnumerateArray())
        {
            if (!d.TryGetProperty("fields", out var f))
            {
                continue;
            }

            var remitente = ReadString(f, "remitenteUid") ?? string.Empty;
            var destinatario = ReadString(f, "destinatarioUid") ?? string.Empty;
            if (!string.Equals(remitente, uid, StringComparison.Ordinal) && !string.Equals(destinatario, uid, StringComparison.Ordinal))
            {
                continue;
            }

            mensajes.Add(new MensajeInterno
            {
                Id = ReadString(f, "id") ?? string.Empty,
                RemitenteUid = remitente,
                RemitenteNombre = ReadString(f, "remitenteNombre") ?? string.Empty,
                DestinatarioUid = destinatario,
                DestinatarioNombre = ReadString(f, "destinatarioNombre") ?? string.Empty,
                Mensaje = ReadString(f, "mensaje") ?? string.Empty,
                Fecha = ReadTimestamp(f, "fecha") ?? DateTime.UtcNow,
                Leido = ReadBool(f, "leido") ?? false
            });
        }

        return mensajes
            .OrderByDescending(m => m.Fecha)
            .ToList();
    }

    public async Task<bool> MarcarLeidoAsync(string mensajeId, bool leido, string idToken)
    {
        if (string.IsNullOrWhiteSpace(mensajeId) || string.IsNullOrWhiteSpace(idToken))
        {
            return false;
        }

        var body = new
        {
            fields = new Dictionary<string, object>
            {
                ["leido"] = new { booleanValue = leido }
            }
        };

        return await CrearDocumentoAsync(Collection, body, mensajeId, idToken);
    }

    private static string? ReadString(JsonElement fields, string key)
    {
        if (!fields.TryGetProperty(key, out var v)) return null;
        if (v.TryGetProperty("stringValue", out var s)) return s.GetString();
        return null;
    }

    private static bool? ReadBool(JsonElement fields, string key)
    {
        if (!fields.TryGetProperty(key, out var v)) return null;
        if (v.TryGetProperty("booleanValue", out var b)) return b.GetBoolean();
        return null;
    }

    private static DateTime? ReadTimestamp(JsonElement fields, string key)
    {
        if (!fields.TryGetProperty(key, out var v)) return null;
        if (!v.TryGetProperty("timestampValue", out var ts)) return null;
        if (!DateTime.TryParse(ts.GetString(), out var parsed)) return null;
        return parsed;
    }
}
