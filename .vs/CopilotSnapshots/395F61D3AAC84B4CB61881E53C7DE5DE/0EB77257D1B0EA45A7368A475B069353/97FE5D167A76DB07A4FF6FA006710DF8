<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.AdminMensajesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FB">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="18,16,18,20" Spacing="12">
                <Label Text="Mensajes de empleados"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#0B1F4D" />

                <Label Text="{Binding DestinatarioActualTexto}" TextColor="#1E40AF" IsVisible="{Binding PuedeMensajeriaAdmin}" />

                <Entry Placeholder="Escribe una respuesta"
                       Text="{Binding MensajeNuevo}"
                       MaxLength="220"
                       IsVisible="{Binding PuedeMensajeriaAdmin}" />

                <Button Text="Enviar respuesta"
                        HeightRequest="42"
                        CornerRadius="10"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        Command="{Binding EnviarMensajeCommand}"
                        IsVisible="{Binding PuedeMensajeriaAdmin}" />

                <CollectionView ItemsSource="{Binding MensajesInternos}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                    Stroke="#E7ECF4"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding RemitenteNombre}" FontSize="14" FontAttributes="Bold" TextColor="#0B1F4D" />
                                    <Label Text="{Binding Mensaje}" FontSize="13" TextColor="#334155" />
                                    <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="11" TextColor="#64748B" />
                                    <Button Text="Responder"
                                            HeightRequest="36"
                                            CornerRadius="10"
                                            BackgroundColor="#EFF6FF"
                                            TextColor="#1E40AF"
                                            FontAttributes="Bold"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PuedeMensajeriaAdmin}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrepararRespuestaCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{Binding ErrorDetalle}" TextColor="#B91C1C" IsVisible="{Binding TieneError}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
