using AutoLavadoApp.Services;
using AutoLavadoApp.ViewModels;
using System;
using System.Collections.ObjectModel;
using System.Threading.Tasks;
using System.Windows.Input;
using AutoLavadoApp.Models;

namespace AutoLavadoApp.ViewModels
{
    public class MisCitasViewModel : BaseViewModel
    {
        private readonly CitaService _citaService;
        private readonly SessionService _sessionService;
        private readonly NotificacionService _notificacionService;

        public ObservableCollection<Cita> Citas { get; } = new();

        private int _notificacionesNoLeidas;
        public int NotificacionesNoLeidas
        {
            get => _notificacionesNoLeidas;
            private set
            {
                if (SetProperty(ref _notificacionesNoLeidas, value))
                {
                    OnPropertyChanged(nameof(TieneNotificacionesNoLeidas));
                    OnPropertyChanged(nameof(NotificacionesNoLeidasTexto));
                }
            }
        }

        public bool TieneNotificacionesNoLeidas => NotificacionesNoLeidas > 0;
        public string NotificacionesNoLeidasTexto => NotificacionesNoLeidas > 9 ? "9+" : NotificacionesNoLeidas.ToString();

        public Func<string, string, string, Task<bool>>? ConfirmarAsync { get; set; }
        public Func<string, string, string, Task>? MostrarAlertaAsync { get; set; }

        public ICommand CargarCommand { get; }
        public ICommand CancelarCommand { get; }

        public MisCitasViewModel(CitaService citaService, SessionService sessionService, NotificacionService notificacionService)
        {
            _citaService = citaService;
            _sessionService = sessionService;
            _notificacionService = notificacionService;

            CargarCommand = new Command(async () => await CargarAsync());
            CancelarCommand = new Command<Cita>(async c => await CancelarAsync(c));
        }

        public async Task CargarAsync()
        {
            if (IsBusy) return;

            try
            {
                IsBusy = true;
                Citas.Clear();

                var uid = _sessionService.ObtenerUid();
                if (string.IsNullOrWhiteSpace(uid))
                {
                    await MostrarAlertaSeguraAsync("Sesión", "No hay sesión activa.");
                    return;
                }

                var token = await _sessionService.ObtenerTokenAsync();
                if (SessionService.TokenExpirado(token))
                {
                    await MostrarAlertaSeguraAsync("Sesión", "Tu sesión expiró. Inicia sesión nuevamente.");
                    return;
                }

                var lista = await _citaService.ObtenerCitasPorUsuarioAsync(uid, token);
                foreach (var c in lista) Citas.Add(c);

                NotificacionesNoLeidas = await _notificacionService.ObtenerNoLeidasCountAsync(uid, token);
            }
            finally
            {
                IsBusy = false;
            }
        }

        public async Task CancelarAsync(Cita? cita)
        {
            if (cita is null) return;
            if (cita.Estado is EstadosCita.Cancelada or EstadosCita.Finalizada) return;

            var confirmar = ConfirmarAsync is not null
                ? await ConfirmarAsync("Cancelar", "¿Deseas cancelar esta cita?", "Sí")
                : false;
            if (!confirmar) return;

            var token = _sessionService.ObtenerToken();
            var ok = await _citaService.CancelarCitaAsync(cita.Id, token);
            if (!ok)
            {
                await MostrarAlertaSeguraAsync("Error", "No se pudo cancelar la cita.");
                return;
            }

            await CargarAsync();
        }

        private async Task MostrarAlertaSeguraAsync(string titulo, string mensaje)
        {
            if (MostrarAlertaAsync is not null)
            {
                await MostrarAlertaAsync(titulo, mensaje, "OK");
            }
        }
    }
}
