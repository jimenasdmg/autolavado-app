<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoLavadoApp.MiCuentaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mi cuenta"
    BackgroundColor="#F5F7FB">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,24" Spacing="20">

            <Label Text="Mi cuenta"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#0F172A" />

            <Border BackgroundColor="#1D4ED8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Padding="18,14">
                <Border.Shadow>
                    <Shadow Brush="#1C000000" Offset="0,4" Radius="10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Border WidthRequest="72"
                            HeightRequest="72"
                            BackgroundColor="#2563EB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 36">
                        <Label Text="{Binding InicialesUsuario}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="{Binding NombreCompleto}" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                        <Label Text="{Binding RolTexto}" FontSize="13" FontAttributes="Bold" TextColor="#BFDBFE" HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Email}" FontSize="13" TextColor="#DBEAFE" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="#E7ECF4"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="14">
                <Border.Shadow>
                    <Shadow Brush="#16000000" Offset="0,3" Radius="10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Button Text="Editar perfil"
                            HeightRequest="46"
                            CornerRadius="12"
                            TextColor="#0B1F4D"
                            BackgroundColor="#EFF6FF"
                            FontAttributes="Bold"
                            ImageSource="{FontImageSource Glyph=&#xF044;, FontFamily=FontAwesomeSolid, Size=14, Color=#0B1F4D}"
                            ContentLayout="Left,8"
                            IsVisible="{Binding PuedeEditarPerfil}"
                            Command="{Binding EditarPerfilCommand}" />

                    <Button Text="Configuración"
                            HeightRequest="46"
                            CornerRadius="12"
                            TextColor="#0B1F4D"
                            BackgroundColor="#EFF6FF"
                            FontAttributes="Bold"
                            ImageSource="{FontImageSource Glyph=&#xF013;, FontFamily=FontAwesomeSolid, Size=14, Color=#0B1F4D}"
                            ContentLayout="Left,8"
                            IsVisible="{Binding PuedeConfigurar}"
                            Command="{Binding ConfiguracionCommand}" />

                    <Button Text="Cerrar sesión"
                            HeightRequest="46"
                            CornerRadius="12"
                            BorderWidth="1"
                            BorderColor="#FCA5A5"
                            BackgroundColor="Transparent"
                            TextColor="#B91C1C"
                            FontFamily="OpenSansSemibold"
                            FontSize="14"
                            ImageSource="{FontImageSource Glyph=&#xF2F5;, FontFamily=FontAwesomeSolid, Size=14, Color=#B91C1C}"
                            ContentLayout="Left,8"
                            Command="{Binding CerrarSesionCommand}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorDetalle}"
                   TextColor="#B91C1C"
                   IsVisible="{Binding TieneError}" />

        </VerticalStackLayout>
    </ScrollView>

    <Grid IsVisible="{Binding IsBusy}"
          BackgroundColor="#80F8FAFC"
          InputTransparent="False">
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#3B82F6" WidthRequest="42" HeightRequest="42" />
            <Label Text="Cargando cuenta..." FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
        </VerticalStackLayout>
    </Grid>
    </Grid>
</ContentPage>
