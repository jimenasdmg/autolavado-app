rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userPath());
    }

    function userDoc() {
      return get(userPath());
    }

    function userRole() {
      return userExists() && (userDoc().data.rol is string)
        ? userDoc().data.rol
        : '';
    }

    function isAdmin() {
      return userRole() == 'admin' || userRole() == 'Admin' || userRole() == 'ADMIN';
    }

    function isEmpleado() {
      return userRole() == 'empleado' || userRole() == 'Empleado' || userRole() == 'EMPLEADO';
    }

    function isCliente() {
      return userRole() == 'cliente' || userRole() == 'Cliente' || userRole() == 'CLIENTE';
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function creatingOwnEmpleadoProfile() {
      return isSignedIn()
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && (
          request.resource.data.rol == 'empleado' ||
          request.resource.data.rol == 'Empleado' ||
          request.resource.data.rol == 'EMPLEADO'
        );
    }

    // =========================
    // USUARIOS
    // =========================

    match /usuarios/{uid} {
      allow create: if isSelf(uid) || isAdmin();
      allow read: if isSelf(uid) || isAdmin();

      allow update: if isAdmin() ||
        (
          isSelf(uid) &&
          request.resource.data.rol == resource.data.rol &&
          request.resource.data.uid == resource.data.uid
        );

      allow delete: if isAdmin();
    }

    // =========================
    // EMPLEADOS
    // =========================

    match /empleados/{empleadoId} {
      allow read: if isAdmin() || (isEmpleado() && resource.data.uid == request.auth.uid);
      allow create: if isAdmin() || creatingOwnEmpleadoProfile();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================
    // SERVICIOS
    // =========================

    match /servicios/{servicioId} {
      allow read: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.activo == true &&
          resource.data.visible == true
        );

      allow write: if isAdmin();
    }

    // =========================
    // VEHICULOS
    // =========================

    match /vehiculos/{vehiculoId} {
      allow create: if isSignedIn() &&
        (
          request.resource.data.usuarioId == request.auth.uid ||
          isAdmin()
        );

      allow read: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.usuarioId == request.auth.uid
        );

      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.usuarioId == request.auth.uid &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.usuarioId == resource.data.usuarioId
        );

      allow delete: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.usuarioId == request.auth.uid
        );
    }

    // =========================
    // CITAS
    // =========================

    match /citas/{citaId} {
      allow create: if isSignedIn() &&
        (
          isAdmin() ||
          (
            isCliente() &&
            request.resource.data.clienteId == request.auth.uid &&
            request.resource.data.keys().hasAll([
              'id',
              'clienteId',
              'servicioId',
              'vehiculoId',
              'fecha',
              'hora',
              'estado',
              'modalidad',
              'fechaCreacion'
            ]) &&
            request.resource.data.servicioId != '' &&
            request.resource.data.vehiculoId != '' &&
            request.resource.data.fecha != '' &&
            request.resource.data.hora != '' &&
            request.resource.data.modalidad != '' &&
            request.resource.data.estado == 'pendiente' &&
            request.resource.data.empleadoId == ''
          )
        );

      allow read: if isAdmin() ||
        (
          isCliente() &&
          resource.data.clienteId == request.auth.uid
        ) ||
        (
          isEmpleado() &&
          (
            resource.data.estado == 'pendiente' ||
            resource.data.empleadoId == request.auth.uid
          )
        );

      allow update: if isAdmin() ||
        (
          isCliente() &&
          resource.data.clienteId == request.auth.uid &&
          request.resource.data.clienteId == resource.data.clienteId &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.servicioId == resource.data.servicioId &&
          request.resource.data.vehiculoId == resource.data.vehiculoId &&
          request.resource.data.fechaCreacion == resource.data.fechaCreacion &&
          request.resource.data.empleadoId == resource.data.empleadoId
        ) ||
        (
          isEmpleado() &&
          (
            (
              resource.data.estado == 'pendiente' &&
              request.resource.data.empleadoId == request.auth.uid &&
              request.resource.data.estado == 'empleado_asignado'
            ) ||
            (
              resource.data.empleadoId == request.auth.uid
            )
          ) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.clienteId == resource.data.clienteId &&
          request.resource.data.servicioId == resource.data.servicioId &&
          request.resource.data.vehiculoId == resource.data.vehiculoId &&
          request.resource.data.fecha == resource.data.fecha &&
          request.resource.data.hora == resource.data.hora &&
          request.resource.data.precio == resource.data.precio &&
          request.resource.data.fechaCreacion == resource.data.fechaCreacion
        );

      allow delete: if isAdmin();
    }

    // =========================
    // NOTIFICACIONES
    // =========================

    match /notificaciones/{notificacionId} {
      allow create: if isAdmin() ||
        (
          isSignedIn() &&
          request.resource.data.usuarioId == request.auth.uid
        );

      allow read, update: if isAdmin() ||
        (
          isSignedIn() &&
          resource.data.usuarioId == request.auth.uid
        );

      allow delete: if isAdmin();
    }

    // =========================
    // MENSAJES
    // =========================

    match /mensajes/{mensajeId} {
      allow create: if isSignedIn() &&
        (
          request.resource.data.remitenteId == request.auth.uid ||
          isAdmin()
        );

      allow read: if isAdmin() ||
        (
          isSignedIn() &&
          (
            resource.data.remitenteId == request.auth.uid ||
            resource.data.destinatarioId == request.auth.uid
          )
        );

      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          (
            resource.data.destinatarioId == request.auth.uid ||
            resource.data.remitenteId == request.auth.uid
          )
        );

      allow delete: if false;
    }

    // =========================
    // OBSERVACIONES
    // =========================

    match /observaciones/{observacionId} {
      allow read: if isAdmin() || isEmpleado();
      allow create: if isAdmin() || isEmpleado();
      allow update: if isAdmin() || isEmpleado();
      allow delete: if isAdmin();
    }

    // Denegar cualquier colección no declarada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
