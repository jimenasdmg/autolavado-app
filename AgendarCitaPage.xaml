<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoLavadoApp.Views.Cliente.AgendarCitaPage"
             Padding="0,18,0,0"
             BackgroundColor="#F5F7FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <ScrollView>

            <VerticalStackLayout x:Name="MainContent"
                                 Padding="24,18"
                                 Spacing="16"
                                 Opacity="0">

               
                <Grid ColumnDefinitions="Auto,*,Auto"
                      VerticalOptions="Center"
                      Margin="24,60,0,0">

                    <Button Text="&#xF060;"
                            WidthRequest="52"
                            HeightRequest="52"
                            Padding="0"
                            FontFamily="FontAwesomeSolid"
                            FontSize="20"
                            CornerRadius="18"
                            BackgroundColor="White"
                            TextColor="#0F172A"
                            Clicked="OnVolverClicked" />

                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="BRIZZO"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="#2563EB" />

                    </VerticalStackLayout>

                </Grid>

                <!-- TITULO -->
                <VerticalStackLayout Spacing="4">

                    <Label Text="Agendar cita"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#0F172A" />

                    <Label Text="Reserva tu lavado y ahorra tiempo."
                           FontSize="14"
                           TextColor="#64748B" />

                </VerticalStackLayout>

                <!-- ERROR -->
                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#FEF2F2"
                        Stroke="#FECACA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,10">

                    <Label Text="{Binding ErrorMessage}"
                           FontSize="13"
                           TextColor="#B91C1C" />

                </Border>

                <!-- METODO PAGO -->
                <Border BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16"
                        MinimumHeightRequest="120">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Método de pago"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <Picker ItemsSource="{Binding MetodosPago}"
                                SelectedItem="{Binding MetodoPagoSeleccionado}"
                                Title="Selecciona método de pago"
                                BackgroundColor="White"
                                TextColor="#0F172A"
                                TitleColor="#94A3B8"
                                HeightRequest="50" />

                    </VerticalStackLayout>

                </Border>

                <HorizontalStackLayout Spacing="10">

                    <!-- SUCURSAL -->
                    <Button Text="Sucursal"
                            Command="{Binding SeleccionarSucursalCommand}"
                            BackgroundColor="{Binding FondoSucursal}"
                            BorderColor="{Binding BordeSucursal}"
                            BorderWidth="1"
                            TextColor="{Binding TextoSucursal}"
                            CornerRadius="12"
                            HeightRequest="42"
                            HorizontalOptions="FillAndExpand" />

                    <!-- DOMICILIO -->
                    <Button Text="A domicilio"
                            Command="{Binding SeleccionarDomicilioCommand}"
                            BackgroundColor="{Binding FondoDomicilio}"
                            BorderColor="{Binding BordeDomicilio}"
                            BorderWidth="1"
                            TextColor="{Binding TextoDomicilio}"
                            CornerRadius="12"
                            HeightRequest="42"
                            HorizontalOptions="FillAndExpand" />

                </HorizontalStackLayout>

                <!-- ENTREGA DEVUELTA -->
                <Border IsVisible="{Binding EsRecoleccion}"
                        BackgroundColor="#EFF6FF"
                        Stroke="#BFDBFE"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">

                    <VerticalStackLayout Spacing="8">

                        <Label Text="¿Deseas entrega de vuelta?"
                               FontAttributes="Bold"
                               TextColor="#1E3A8A" />

                        <Label Text="Se agregan $50 extra al servicio."
                               FontSize="12"
                               TextColor="#64748B" />

                        <Switch IsToggled="{Binding EntregaDevueltaSeleccionada}" />

                    </VerticalStackLayout>

                </Border>
              
                <!-- DIRECCION DOMICILIO -->
                <Border IsVisible="{Binding EsRecoleccion}"
                        BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Datos de entrega"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <Entry Placeholder="Calle y número"
                               Text="{Binding Calle}"
                               BackgroundColor="White"
                               TextColor="#0F172A"
                               PlaceholderColor="#94A3B8"
                               HeightRequest="50" />

                        <Entry Placeholder="Código postal"
                               Text="{Binding CodigoPostal}"
                               Keyboard="Numeric"
                               MaxLength="5"
                               BackgroundColor="White"
                               TextColor="#0F172A"
                               PlaceholderColor="#94A3B8"
                               HeightRequest="50" />

                        <Entry Placeholder="Colonia"
                               Text="{Binding Colonia}"
                               BackgroundColor="White"
                               TextColor="#0F172A"
                               PlaceholderColor="#94A3B8"
                               HeightRequest="50" />

                        <Entry Placeholder="Referencias"
                               Text="{Binding Referencias}"
                               BackgroundColor="White"
                               TextColor="#0F172A"
                               PlaceholderColor="#94A3B8"
                               HeightRequest="50" />

                    </VerticalStackLayout>

                </Border>

                <!-- SERVICIOS -->
                <Border BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Paso 1 · Seleccionar servicio"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <CollectionView ItemsSource="{Binding Servicios}"
                                        SelectionMode="None">

                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout ItemSpacing="10"
                                                   Orientation="Vertical" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>

                                <DataTemplate>

                                    <Border BackgroundColor="{Binding Fondo}"
                                            Stroke="{Binding Borde}"
                                            StrokeThickness="1.4"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="12">

                                        <Border.GestureRecognizers>

                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarServicioCommand}"
                                                                  CommandParameter="{Binding .}" />

                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10">

                                            <Border BackgroundColor="#DBEAFE"
                                                    StrokeShape="RoundRectangle 10"
                                                    Padding="8"
                                                    VerticalOptions="Center"
                                                    WidthRequest="36"
                                                    HeightRequest="36">

                                                <Label Text="✦"
                                                       FontSize="14"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="#1D4ED8" />

                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">

                                                <Label Text="{Binding Nombre}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="#0F172A" />

                                                <Label Text="{Binding Descripcion}"
                                                       FontSize="12"
                                                       TextColor="#64748B"
                                                       MaxLines="2" />

                                                <Label Text="{Binding PrecioTexto}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#2563EB" />

                                            </VerticalStackLayout>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

                <!-- FECHA Y HORA -->
                <Border BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <Label Text="Paso 1 · Seleccionar fecha"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <DatePicker Date="{Binding FechaSeleccionada}"
                                    MinimumDate="{Binding FechaMinima}"
                                    TextColor="#0F172A" />

                        <Label Text="Paso 2 · Seleccionar hora"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <FlexLayout Wrap="Wrap"
                                    Direction="Row"
                                    JustifyContent="Start">

                            <Button Text="08:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="08:00"
                                    Margin="4" />

                            <Button Text="09:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="09:00"
                                    Margin="4" />

                            <Button Text="10:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="10:00"
                                    Margin="4" />

                            <Button Text="11:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="11:00"
                                    Margin="4" />

                            <Button Text="12:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="12:00"
                                    Margin="4" />

                            <Button Text="13:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="13:00"
                                    Margin="4" />

                            <Button Text="14:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="14:00"
                                    Margin="4" />

                            <Button Text="15:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="15:00"
                                    Margin="4" />

                            <Button Text="16:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="16:00"
                                    Margin="4" />

                            <Button Text="17:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="17:00"
                                    Margin="4" />

                            <Button Text="18:00"
                                    WidthRequest="90"
                                    HeightRequest="60"
                                    Command="{Binding SeleccionarHoraCommand}"
                                    CommandParameter="18:00"
                                    Margin="4" />

                        </FlexLayout>

                    </VerticalStackLayout>

                </Border>

                <!-- VEHICULO -->
                <Border BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16"
                        MinimumHeightRequest="170">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Vehículo"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <CollectionView ItemsSource="{Binding Vehiculos}"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding VehiculoSeleccionado}">

                            <CollectionView.ItemTemplate>

                                <DataTemplate>

                                    <Border Stroke="{Binding BorderColor}"
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 20"
                                            BackgroundColor="White"
                                            Padding="16"
                                            Margin="0,0,0,12">

                                        <VerticalStackLayout Spacing="6">

                                            <Label Text="{Binding Marca}"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   TextColor="#0F172A" />

                                            <Label Text="{Binding Modelo}"
                                                   FontSize="18"
                                                   TextColor="#64748B" />

                                            <Label Text="{Binding Placa}"
                                                   FontSize="18"
                                                   TextColor="#2563EB" />

                                        </VerticalStackLayout>
                                    </Border>

                                </DataTemplate>


                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <Button Text="Agregar vehículo"
                                HeightRequest="40"
                                CornerRadius="12"
                                BackgroundColor="#EFF6FF"
                                TextColor="#1D4ED8"
                                FontAttributes="Bold"
                                Clicked="OnAgregarVehiculoClicked" />

                    </VerticalStackLayout>

                </Border>

                <!-- RESUMEN -->
                <Border BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="16">

                    <Border.Shadow>
                        <Shadow Brush="#14000000"
                                Offset="0,4"
                                Radius="12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">

                        <Label Text="Tu cita"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">

                            <!-- SERVICIO -->
                            <Label Grid.Row="0"
                                   Text="Servicio:"
                                   FontSize="13"
                                   TextColor="#64748B" />

                            <Label Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{Binding ResumenServicio}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />

                            <!-- FECHA -->
                            <Label Grid.Row="1"
                                   Text="Fecha:"
                                   FontSize="13"
                                   TextColor="#64748B" />

                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding ResumenFecha}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />

                            <!-- HORA -->
                            <Label Grid.Row="2"
                                   Text="Hora:"
                                   FontSize="13"
                                   TextColor="#64748B" />

                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding ResumenHora}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />

                            <!-- TOTAL -->
                            <Label Grid.Row="3"
                                   Text="Total:"
                                   FontSize="13"
                                   TextColor="#64748B" />

                            <Label Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding TotalPrecioTexto}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />

                        </Grid>

                        <!-- BOTON -->
                        <Button Text="Confirmar cita"
                                HeightRequest="52"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                FontSize="16"
                                Command="{Binding ConfirmarCitaCommand}"
                                IsEnabled="{Binding PuedeConfirmar}"
                                TextColor="White">

                            <Button.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">

                                    <GradientStop Color="#1D4ED8"
                                                  Offset="0" />

                                    <GradientStop Color="#2563EB"
                                                  Offset="0.5" />

                                    <GradientStop Color="#3B82F6"
                                                  Offset="1" />

                                </LinearGradientBrush>

                            </Button.Background>

                            <Button.Shadow>

                                <Shadow Brush="#302563EB"
                                        Offset="0,4"
                                        Radius="10" />

                            </Button.Shadow>

                        </Button>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>

        </ScrollView>

        <!-- LOADING -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80F8FAFC"
              InputTransparent="False">

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8">

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="#2563EB"
                                   WidthRequest="44"
                                   HeightRequest="44" />

                <Label Text="Preparando agenda..."
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#0F172A" />

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>